<?xml version="1.0" encoding="UTF-8"?>
<!-- OpenGL Settings window for xnec2c — per-type brightness/transparency -->
<interface>
  <requires lib="gtk+" version="3.20"/>

  <!-- Adjustments — brightness (0=black, 1=full) -->
  <object class="GtkAdjustment" id="adj_bright_segments">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">1</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_bright_patches">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">1</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_bright_rdpat_surface">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">0.47</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_bright_rdpat_wire">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">1</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_bright_nearfield">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">1</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_bright_ground_plane">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">1</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_bright_axes">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">1</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>

  <!-- Adjustments — transparency (0=opaque, 1=invisible) -->
  <object class="GtkAdjustment" id="adj_trans_segments">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">0.5</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_trans_patches">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">0.5</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_trans_rdpat_surface">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">0.5</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_trans_rdpat_wire">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">0.5</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_trans_nearfield">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">0</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_trans_ground_plane">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">0.5</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_trans_axes">
    <property name="lower">0</property><property name="upper">1</property>
    <property name="value">0</property><property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>

  <object class="GtkAdjustment" id="adj_cylinder_scale">
    <property name="lower">0.1</property>
    <property name="upper">10</property>
    <property name="value">1</property>
    <property name="step-increment">0.1</property>
    <property name="page-increment">1</property>
  </object>

  <object class="GtkWindow" id="opengl_settings_window">
    <property name="can-focus">False</property>
    <property name="title" translatable="yes">OpenGL Settings</property>
    <property name="default-width">480</property>
    <property name="default-height">-1</property>
    <property name="destroy-with-parent">True</property>
    <signal name="delete-event" handler="on_opengl_settings_window_delete_event" swapped="no"/>
    <signal name="destroy" handler="on_opengl_settings_window_destroy" swapped="no"/>
    <child>
      <object class="GtkBox" id="opengl_settings_vbox">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="orientation">vertical</property>
        <property name="spacing">6</property>
        <property name="margin-start">8</property>
        <property name="margin-end">8</property>
        <property name="margin-top">8</property>
        <property name="margin-bottom">8</property>

        <!-- Rendering frame -->
        <child>
          <object class="GtkFrame">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="label-xalign">0</property>
            <property name="shadow-type">none</property>
            <child type="label">
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="label">Rendering</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="orientation">vertical</property>
                <property name="spacing">4</property>
                <property name="margin-start">12</property>
                <property name="margin-top">4</property>
                <child>
                  <object class="GtkCheckButton" id="chk_opengl_renderer">
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                    <property name="label" translatable="yes">OpenGL Renderer</property>
                    <property name="active">True</property>
                    <property name="tooltip-text">Enable hardware-accelerated OpenGL rendering</property>
                    <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkCheckButton" id="chk_constrained_rotation">
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                    <property name="label" translatable="yes">Constrained Rotation</property>
                    <property name="active">True</property>
                    <property name="tooltip-text">Restrict arcball rotation to a single axis</property>
                    <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkCheckButton" id="chk_orthographic">
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                    <property name="label" translatable="yes">Orthographic Projection</property>
                    <property name="tooltip-text">Use orthographic projection; disables perspective foreshortening.
Enable for precise angular measurements or flat pattern inspection.</property>
                    <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">2</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkBox">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="orientation">horizontal</property>
                    <property name="spacing">4</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="label">MSAA Samples</property>
                        <property name="xalign">0</property>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">False</property>
                        <property name="position">0</property>
                      </packing>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">3</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkBox">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="orientation">horizontal</property>
                    <property name="spacing">8</property>
                    <property name="margin-start">12</property>
                    <child>
                      <object class="GtkRadioButton" id="radio_msaa_off">
                        <property name="visible">True</property>
                        <property name="can-focus">True</property>
                        <property name="label">Off</property>
                        <property name="tooltip-text">Disable multi-sample anti-aliasing</property>
                        <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">False</property>
                        <property name="position">0</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkRadioButton" id="radio_msaa_2x">
                        <property name="visible">True</property>
                        <property name="can-focus">True</property>
                        <property name="label">2x</property>
                        <property name="group">radio_msaa_off</property>
                        <property name="tooltip-text">2x multi-sample anti-aliasing</property>
                        <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">False</property>
                        <property name="position">1</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkRadioButton" id="radio_msaa_4x">
                        <property name="visible">True</property>
                        <property name="can-focus">True</property>
                        <property name="label">4x</property>
                        <property name="group">radio_msaa_off</property>
                        <property name="tooltip-text">4x multi-sample anti-aliasing</property>
                        <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">False</property>
                        <property name="position">2</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkRadioButton" id="radio_msaa_8x">
                        <property name="visible">True</property>
                        <property name="can-focus">True</property>
                        <property name="label">8x</property>
                        <property name="group">radio_msaa_off</property>
                        <property name="tooltip-text">8x multi-sample anti-aliasing — higher GPU cost</property>
                        <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">False</property>
                        <property name="position">3</property>
                      </packing>
                    </child>
                    <child>
                      <object class="GtkRadioButton" id="radio_msaa_16x">
                        <property name="visible">True</property>
                        <property name="can-focus">True</property>
                        <property name="label">16x</property>
                        <property name="group">radio_msaa_off</property>
                        <property name="tooltip-text">16x multi-sample anti-aliasing — highest quality, highest GPU cost</property>
                        <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                      </object>
                      <packing>
                        <property name="expand">False</property>
                        <property name="fill">False</property>
                        <property name="position">4</property>
                      </packing>
                    </child>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">4</property>
                  </packing>
                </child>
              </object>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">0</property>
          </packing>
        </child>

        <!-- ============ Structure ============ -->
        <child>
          <object class="GtkFrame">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="label-xalign">0</property>
            <property name="shadow-type">none</property>
            <child type="label">
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="label">Structure</property>
                <attributes><attribute name="weight" value="bold"/></attributes>
              </object>
            </child>
            <child>
              <object class="GtkGrid">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="row-spacing">4</property>
                <property name="column-spacing">8</property>
                <property name="margin-start">12</property>
                <property name="margin-top">4</property>
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label"></property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                </child>
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Brightness</property><attributes><attribute name="scale" value="0.9"/></attributes></object>
                  <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                </child>
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Transparency</property><attributes><attribute name="scale" value="0.9"/></attributes></object>
                  <packing><property name="left-attach">2</property><property name="top-attach">0</property></packing>
                </child>
                <!-- Segments -->
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Segments</property><property name="xalign">0</property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_bright_segments">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_bright_segments</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Brightness of wire segment cylinders (0=black, 1=full)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_trans_segments">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_trans_segments</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Transparency of wire segments (0=opaque, 1=invisible)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">2</property><property name="top-attach">1</property></packing>
                </child>
                <!-- Patches -->
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Patches</property><property name="xalign">0</property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_bright_patches">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_bright_patches</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Brightness of surface patches (0=black, 1=full)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_trans_patches">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_trans_patches</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Transparency of surface patches (0=opaque, 1=invisible)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">2</property><property name="top-attach">2</property></packing>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- ============ Radiation Pattern ============ -->
        <child>
          <object class="GtkFrame">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="label-xalign">0</property>
            <property name="shadow-type">none</property>
            <child type="label">
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="label">Radiation Pattern</property>
                <attributes><attribute name="weight" value="bold"/></attributes>
              </object>
            </child>
            <child>
              <object class="GtkGrid">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="row-spacing">4</property>
                <property name="column-spacing">8</property>
                <property name="margin-start">12</property>
                <property name="margin-top">4</property>
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label"></property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                </child>
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Brightness</property><attributes><attribute name="scale" value="0.9"/></attributes></object>
                  <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                </child>
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Transparency</property><attributes><attribute name="scale" value="0.9"/></attributes></object>
                  <packing><property name="left-attach">2</property><property name="top-attach">0</property></packing>
                </child>
                <!-- Surface -->
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Surface</property><property name="xalign">0</property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_bright_rdpat_surface">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_bright_rdpat_surface</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Brightness of radiation pattern filled surface (0=black, 1=full). In Both mode, dimmed further so wireframe lines stand out.</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_trans_rdpat_surface">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_trans_rdpat_surface</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Transparency of radiation pattern surface (0=opaque, 1=invisible)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">2</property><property name="top-attach">1</property></packing>
                </child>
                <!-- Wireframe -->
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Wireframe</property><property name="xalign">0</property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_bright_rdpat_wire">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_bright_rdpat_wire</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Brightness of radiation pattern wireframe lines (0=black, 1=full)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_trans_rdpat_wire">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_trans_rdpat_wire</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Transparency of radiation pattern wireframe (0=opaque, 1=invisible)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">2</property><property name="top-attach">2</property></packing>
                </child>
                <!-- Near-field -->
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Near-field</property><property name="xalign">0</property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">3</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_bright_nearfield">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_bright_nearfield</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Brightness of near-field visualization lines (0=black, 1=full)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">1</property><property name="top-attach">3</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_trans_nearfield">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_trans_nearfield</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Transparency of near-field lines (0=opaque, 1=invisible)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">2</property><property name="top-attach">3</property></packing>
                </child>
                <!-- Draw Style -->
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Draw Style</property><property name="xalign">0</property><property name="margin-top">4</property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">4</property></packing>
                </child>
                <child>
                  <object class="GtkBox">
                    <property name="visible">True</property><property name="can-focus">False</property><property name="orientation">horizontal</property><property name="spacing">8</property><property name="margin-top">4</property>
                    <child>
                      <object class="GtkRadioButton" id="radio_style_surface">
                        <property name="visible">True</property><property name="can-focus">True</property><property name="label">Surface</property>
                        <property name="tooltip-text">Render radiation pattern as filled triangulated surface</property>
                        <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkRadioButton" id="radio_style_wireframe">
                        <property name="visible">True</property><property name="can-focus">True</property><property name="label">Wireframe</property>
                        <property name="group">radio_style_surface</property>
                        <property name="tooltip-text">Render radiation pattern as wireframe lines</property>
                        <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                      </object>
                    </child>
                    <child>
                      <object class="GtkRadioButton" id="radio_style_both">
                        <property name="visible">True</property><property name="can-focus">True</property><property name="label">Both</property>
                        <property name="group">radio_style_surface</property>
                        <property name="tooltip-text">Render radiation pattern with surface and wireframe overlay</property>
                        <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                      </object>
                    </child>
                  </object>
                  <packing><property name="left-attach">1</property><property name="top-attach">4</property><property name="width">2</property></packing>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- ============ Scene ============ -->
        <child>
          <object class="GtkFrame">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="label-xalign">0</property>
            <property name="shadow-type">none</property>
            <child type="label">
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="label">Scene</property>
                <attributes><attribute name="weight" value="bold"/></attributes>
              </object>
            </child>
            <child>
              <object class="GtkGrid">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="row-spacing">4</property>
                <property name="column-spacing">8</property>
                <property name="margin-start">12</property>
                <property name="margin-top">4</property>
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label"></property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                </child>
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Brightness</property><attributes><attribute name="scale" value="0.9"/></attributes></object>
                  <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                </child>
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Transparency</property><attributes><attribute name="scale" value="0.9"/></attributes></object>
                  <packing><property name="left-attach">2</property><property name="top-attach">0</property></packing>
                </child>
                <!-- Ground -->
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Ground</property><property name="xalign">0</property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_bright_ground_plane">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_bright_ground_plane</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Brightness of the ground plane grid (0=black, 1=full)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_trans_ground_plane">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_trans_ground_plane</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Transparency of the ground plane (0=opaque, 1=invisible)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">2</property><property name="top-attach">1</property></packing>
                </child>
                <!-- Axes -->
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Axes</property><property name="xalign">0</property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_bright_axes">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_bright_axes</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Brightness of the coordinate axes (0=black, 1=full)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_trans_axes">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_trans_axes</property><property name="digits">2</property><property name="value-pos">right</property>
                    <property name="tooltip-text">Transparency of the coordinate axes (0=opaque, 1=invisible)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">2</property><property name="top-attach">2</property></packing>
                </child>
                <!-- Only on Click -->
                <child>
                  <object class="GtkCheckButton" id="chk_only_on_click">
                    <property name="visible">True</property><property name="can-focus">True</property>
                    <property name="label">Transparency Only on Click</property><property name="active">True</property><property name="margin-top">4</property>
                    <property name="tooltip-text">Apply per-type transparency only while dragging; otherwise always active</property>
                    <signal name="toggled" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">0</property><property name="top-attach">3</property><property name="width">3</property></packing>
                </child>
                <!-- Cylinder Scale -->
                <child>
                  <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property><property name="label">Cylinder Scale</property><property name="xalign">0</property><property name="margin-top">4</property></object>
                  <packing><property name="left-attach">0</property><property name="top-attach">4</property></packing>
                </child>
                <child>
                  <object class="GtkScale" id="scale_cylinder_scale">
                    <property name="visible">True</property><property name="can-focus">True</property><property name="hexpand">True</property>
                    <property name="adjustment">adj_cylinder_scale</property><property name="digits">2</property><property name="value-pos">right</property><property name="margin-top">4</property>
                    <property name="tooltip-text">Visual thickness of wire segments (does not affect NEC2 model calculations)</property>
                    <signal name="value-changed" handler="on_opengl_settings_changed" swapped="no"/>
                  </object>
                  <packing><property name="left-attach">1</property><property name="top-attach">4</property><property name="width">2</property></packing>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="visible">True</property><property name="can-focus">False</property>
                    <property name="label" translatable="yes">Visual only — does not affect NEC2 model calculations.</property>
                    <property name="xalign">0</property><property name="margin-start">4</property>
                    <attributes><attribute name="style" value="italic"/><attribute name="scale" value="0.85"/></attributes>
                  </object>
                  <packing><property name="left-attach">0</property><property name="top-attach">5</property><property name="width">3</property></packing>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- Button bar -->
        <child>
          <object class="GtkButtonBox">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="layout-style">end</property>
            <property name="spacing">6</property>
            <child>
              <object class="GtkButton" id="btn_reset">
                <property name="label" translatable="yes">Reset to _Defaults</property>
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="receives-default">True</property>
                <property name="use-underline">True</property>
                <property name="tooltip-text">Reset all OpenGL settings to defaults (renderer toggle and rotation mode unchanged)</property>
                <signal name="clicked" handler="on_opengl_settings_reset_clicked" swapped="no"/>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
                <property name="secondary">True</property>
              </packing>
            </child>
            <child>
              <object class="GtkButton" id="btn_close">
                <property name="label" translatable="yes">_Close</property>
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="receives-default">True</property>
                <property name="use-underline">True</property>
                <signal name="clicked" handler="on_opengl_settings_close_clicked" swapped="no"/>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">1</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">4</property>
          </packing>
        </child>
      </object>
    </child>
  </object>
</interface>
