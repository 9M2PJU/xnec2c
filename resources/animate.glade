        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="tooltip-text" translatable="yes">Hue shows the peak magnitude s(n); brightness follows the traveling wave |cos(arg z + φ)|, floored so nulls stay visible.&#10;&#10;Animated: bright regions sweep along the structure as the phase advances.</property>
