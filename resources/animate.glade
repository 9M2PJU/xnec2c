        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="tooltip-text" translatable="yes">Diverging hue shows the instantaneous sign of the displayed quantity: cold negative, hot positive; brightness carries the magnitude s(n).&#10;&#10;Animated: regions swap poles as the phase advances.</property>
