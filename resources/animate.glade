      <object class="GtkRadioMenuItem" id="anim_famsel_power">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="tooltip-text" translatable="yes">Power-law transfer n^γ of the normalized magnitude.&#10;&#10;γ = 1 is linear amplitude; γ = 0.5 expands weak regions; γ = 2 shows the squared magnitude — |I|² is proportional to per-segment dissipated power (and its radiated-power contribution via radiation resistance), |q|² to stored electrostatic energy.</property>
        <property name="label" translatable="yes">Power</property>
        <property name="active">True</property>
        <property name="draw-as-radio">True</property>
        <signal name="activate" handler="on_config_widget_changed" swapped="no"/>
