    <child>
      <object class="GtkRadioMenuItem" id="anim_famsel_db">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="tooltip-text" translatable="yes">Logarithmic transfer over a user range R, the RF-standard 20·log₁₀ amplitude decibels.&#10;&#10;R sets the visible dynamic range; detail below the floor 10^(−R/20) clips to the bottom color.</property>
        <property name="label" translatable="yes">dB</property>
        <property name="draw-as-radio">True</property>
        <property name="group">anim_famsel_power</property>
        <signal name="activate" handler="on_config_widget_changed" swapped="no"/>
      </object>
    </child>
    <child>
      <object class="GtkRadioMenuItem" id="anim_famsel_asinh">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="tooltip-text" translatable="yes">Inverse hyperbolic sine: linear below the knee k, logarithmic above.&#10;&#10;Keeps near-null currents visible while compressing strong peaks, like a lin-log instrument scale.</property>
        <property name="label" translatable="yes">Asinh</property>
        <property name="draw-as-radio">True</property>
        <property name="group">anim_famsel_power</property>
        <signal name="activate" handler="on_config_widget_changed" swapped="no"/>
      </object>
    </child>
    <child>
      <object class="GtkRadioMenuItem" id="anim_famsel_mulaw">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="tooltip-text" translatable="yes">μ-law companding, the telephony-standard bounded log curve.&#10;&#10;Lifts weak detail without a hard floor; 48.16 dB compression is the classic μ = 255.</property>
        <property name="label" translatable="yes">μ-law</property>
        <property name="draw-as-radio">True</property>
        <property name="group">anim_famsel_power</property>
        <signal name="activate" handler="on_config_widget_changed" swapped="no"/>
      </object>
    </child>
    <child>
      <object class="GtkRadioMenuItem" id="anim_famsel_reinhard">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="tooltip-text" translatable="yes">Reinhard rational compressor (1+k)·n/(n+k), the photographic HDR tone-map.&#10;&#10;Preserves midtones while rolling highlights off smoothly; k sets the knee.</property>
        <property name="label" translatable="yes">Reinhard</property>
        <property name="draw-as-radio">True</property>
        <property name="group">anim_famsel_power</property>
        <signal name="activate" handler="on_config_widget_changed" swapped="no"/>
      </object>
    </child>
    <child>
      <object class="GtkRadioMenuItem" id="anim_famsel_sigmoid">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="tooltip-text" translatable="yes">Hyperbolic tangent soft limiter tanh(a·n)/tanh(a).&#10;&#10;Raises midrange contrast and saturates gently toward the peak, like amplifier compression; a sets the steepness.</property>
        <property name="label" translatable="yes">Sigmoid</property>
        <property name="draw-as-radio">True</property>
        <property name="group">anim_famsel_power</property>
        <signal name="activate" handler="on_config_widget_changed" swapped="no"/>
      </object>
    </child>
    <child>
