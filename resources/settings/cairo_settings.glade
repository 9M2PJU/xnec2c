<?xml version="1.0" encoding="UTF-8"?>
<!-- Cairo rendering tab content for rendering settings dialog.
     Loaded by render_settings_init() alongside render_settings.glade
     and settings/opengl_settings.glade; appended as a GtkNotebook page. -->
<interface>
  <requires lib="gtk+" version="3.20"/>

  <object class="GtkAdjustment" id="adj_cairo_depth_bins">
    <property name="lower">1</property><property name="upper">65535</property>
    <property name="value">0</property><property name="step-increment">1</property>
    <property name="page-increment">16</property>
  </object>

  <object class="GtkBox" id="cairo_tab_content">
    <property name="visible">True</property>
    <property name="can-focus">False</property>
    <property name="orientation">vertical</property>
    <property name="spacing">8</property>
    <property name="margin-start">8</property>
    <property name="margin-end">8</property>
    <property name="margin-top">8</property>
    <property name="margin-bottom">8</property>

    <child>
      <object class="GtkGrid">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="row-spacing">6</property>
        <property name="column-spacing">12</property>

        <!-- Anti-aliasing -->
        <child>
          <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property>
            <property name="label" translatable="yes">Anti-aliasing</property><property name="xalign">0</property>
          </object>
          <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
        </child>
        <child>
          <object class="GtkBox"><property name="visible">True</property><property name="spacing">4</property>
            <child><object class="GtkRadioButton" id="radio_cairo_antialias_default">
              <property name="visible">True</property><property name="can-focus">True</property>
              <property name="label" translatable="yes">Default</property>
              <property name="active">True</property>
              <property name="tooltip-text">Cairo default anti-aliasing; quality depends on backend</property>
              <signal name="toggled" handler="on_config_widget_changed" swapped="no"/>
            </object></child>
            <child><object class="GtkRadioButton" id="radio_cairo_antialias_fast">
              <property name="visible">True</property><property name="can-focus">True</property>
              <property name="label" translatable="yes">Fast</property>
              <property name="group">radio_cairo_antialias_default</property>
              <property name="tooltip-text">Faster anti-aliasing with reduced quality; lower CPU cost per stroke</property>
              <signal name="toggled" handler="on_config_widget_changed" swapped="no"/>
            </object></child>
            <child><object class="GtkRadioButton" id="radio_cairo_antialias_none">
              <property name="visible">True</property><property name="can-focus">True</property>
              <property name="label" translatable="yes">None</property>
              <property name="group">radio_cairo_antialias_default</property>
              <property name="tooltip-text">Disable anti-aliasing; fastest rendering, aliased edges</property>
              <signal name="toggled" handler="on_config_widget_changed" swapped="no"/>
            </object></child>
          </object>
          <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
        </child>

        <!-- Color Quantization -->
        <child>
          <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property>
            <property name="label" translatable="yes">Color Quantization</property><property name="xalign">0</property>
            <property name="tooltip-text">Quantize segment colors to increase stroke batching; reduces cairo_stroke calls</property>
          </object>
          <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
        </child>
        <child>
          <object class="GtkBox"><property name="visible">True</property><property name="spacing">4</property>
            <child><object class="GtkRadioButton" id="radio_cairo_color_quant_off">
              <property name="visible">True</property><property name="can-focus">True</property>
              <property name="label" translatable="yes">Off</property>
              <property name="active">True</property>
              <property name="tooltip-text">Full color precision</property>
              <signal name="toggled" handler="on_config_widget_changed" swapped="no"/>
            </object></child>
            <child><object class="GtkRadioButton" id="radio_cairo_color_quant_8">
              <property name="visible">True</property><property name="can-focus">True</property>
              <property name="label" translatable="yes">8</property>
              <property name="group">radio_cairo_color_quant_off</property>
              <property name="tooltip-text">8 color levels per channel — maximum batching, visible banding on gradients</property>
              <signal name="toggled" handler="on_config_widget_changed" swapped="no"/>
            </object></child>
            <child><object class="GtkRadioButton" id="radio_cairo_color_quant_64">
              <property name="visible">True</property><property name="can-focus">True</property>
              <property name="label" translatable="yes">64</property>
              <property name="group">radio_cairo_color_quant_off</property>
              <property name="tooltip-text">64 color levels per channel</property>
              <signal name="toggled" handler="on_config_widget_changed" swapped="no"/>
            </object></child>
            <child><object class="GtkRadioButton" id="radio_cairo_color_quant_128">
              <property name="visible">True</property><property name="can-focus">True</property>
              <property name="label" translatable="yes">128</property>
              <property name="group">radio_cairo_color_quant_off</property>
              <property name="tooltip-text">128 color levels per channel — good batching, minimal banding</property>
              <signal name="toggled" handler="on_config_widget_changed" swapped="no"/>
            </object></child>
            <child><object class="GtkRadioButton" id="radio_cairo_color_quant_256">
              <property name="visible">True</property><property name="can-focus">True</property>
              <property name="label" translatable="yes">256</property>
              <property name="group">radio_cairo_color_quant_off</property>
              <property name="tooltip-text">256 color levels per channel — near-lossless, moderate batching</property>
              <signal name="toggled" handler="on_config_widget_changed" swapped="no"/>
            </object></child>
          </object>
          <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
        </child>

        <!-- Line Cap -->
        <child>
          <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property>
            <property name="label" translatable="yes">Line Cap</property><property name="xalign">0</property>
          </object>
          <packing><property name="left-attach">0</property><property name="top-attach">3</property></packing>
        </child>
        <child>
          <object class="GtkBox"><property name="visible">True</property><property name="spacing">4</property>
            <child><object class="GtkRadioButton" id="radio_cairo_line_cap_butt">
              <property name="visible">True</property><property name="can-focus">True</property>
              <property name="label" translatable="yes">Butt</property>
              <property name="active">True</property>
              <property name="tooltip-text">Line ends cut flat at the endpoint; no overshoot</property>
              <signal name="toggled" handler="on_config_widget_changed" swapped="no"/>
            </object></child>
            <child><object class="GtkRadioButton" id="radio_cairo_line_cap_round">
              <property name="visible">True</property><property name="can-focus">True</property>
              <property name="label" translatable="yes">Round</property>
              <property name="group">radio_cairo_line_cap_butt</property>
              <property name="tooltip-text">Semicircular cap extending half line-width past the endpoint</property>
              <signal name="toggled" handler="on_config_widget_changed" swapped="no"/>
            </object></child>
            <child><object class="GtkRadioButton" id="radio_cairo_line_cap_square">
              <property name="visible">True</property><property name="can-focus">True</property>
              <property name="label" translatable="yes">Square</property>
              <property name="group">radio_cairo_line_cap_butt</property>
              <property name="tooltip-text">Square cap extending half line-width past the endpoint</property>
              <signal name="toggled" handler="on_config_widget_changed" swapped="no"/>
            </object></child>
          </object>
          <packing><property name="left-attach">1</property><property name="top-attach">3</property></packing>
        </child>

        <!-- Depth Bins -->
        <child>
          <object class="GtkLabel"><property name="visible">True</property><property name="can-focus">False</property>
            <property name="label" translatable="yes">Depth Bins</property><property name="xalign">0</property>
            <property name="tooltip-text">Depth sorting z-quantization bins for painter's algorithm.
1=fastest (color-only sort, no depth distinction); 16=default;
higher=finer depth precision but slower due to reduced batch grouping.</property>
          </object>
          <packing><property name="left-attach">0</property><property name="top-attach">4</property></packing>
        </child>
        <child>
          <object class="GtkSpinButton" id="spin_cairo_depth_bins">
            <property name="visible">True</property><property name="can-focus">True</property>
            <property name="adjustment">adj_cairo_depth_bins</property>
            <property name="digits">0</property>
            <property name="numeric">True</property>
            <property name="tooltip-text">1=fastest (color-only sort, no depth);
16=default; higher=finer depth ordering but slower rendering</property>
            <signal name="value-changed" handler="on_config_widget_changed" swapped="no"/>
          </object>
          <packing><property name="left-attach">1</property><property name="top-attach">4</property></packing>
        </child>

      </object>
      <packing><property name="expand">False</property><property name="fill">True</property><property name="position">0</property></packing>
    </child>

    <!-- Per-tab Reset button -->
    <child>
      <object class="GtkButtonBox" id="cairo_tab_buttonbox">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="layout-style">end</property>
        <property name="margin-top">8</property>
        <child>
          <object class="GtkButton" id="btn_cairo_reset">
            <property name="label" translatable="yes">Reset to _Defaults</property>
            <property name="visible">True</property>
            <property name="can-focus">True</property>
            <property name="receives-default">True</property>
            <property name="use-underline">True</property>
            <property name="tooltip-text">Reset Cairo anti-aliasing, depth bins, color quantization, and line cap to defaults</property>
            <signal name="clicked" handler="on_cairo_tab_reset_clicked" swapped="no"/>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">0</property>
          </packing>
        </child>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">1</property>
      </packing>
    </child>
  </object>

</interface>
