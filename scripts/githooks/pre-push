#!/bin/bash
#
# Block a push that introduces a new fuzzy or new untranslated catalog entry
# relative to the shared-history base. Delta-scoped: pre-existing fuzzy or
# untranslated entries on already-pushed history never block, and update-po
# line-number churn is ignored because entries are keyed by identity.
#
# Read-only: inspects catalog blobs at the pushed commit and at the base;
# never runs update-po and never mutates the tree.
#
# Bypass:  FORCE_PUSH=true git push ...
#
# Installed by scripts/trans-update.sh --sync via core.hooksPath.

set -euo pipefail

[ "${FORCE_PUSH:-}" = "true" ] && exit 0

cd "$(git rev-parse --show-toplevel)"

remote=${1:-}

# Resolve the commit a pushed ref is diffed against: the remote-tracked commit
# when git reports one, else the merge-base with the remote HEAD for a new
# branch, else the empty tree so every catalog entry counts as introduced.
resolve_base() {
	local remote_sha=$1 local_sha=$2 mb
	if [ -n "${remote_sha//0/}" ]; then
		printf '%s\n' "$remote_sha"
		return 0
	fi
	if mb=$(git merge-base "$local_sha" "refs/remotes/$remote/HEAD" 2>/dev/null); then
		printf '%s\n' "$mb"
		return 0
	fi
	printf '%s\n' 4b825dc642cb6eb9a060e54bf8d69288fbee4904
	return 0
}

# Emit the authoritative language codes, dropping comment and blank lines.
linguas() {
	grep -v '^[[:space:]]*#' po/LINGUAS | grep -v '^[[:space:]]*$'
	return 0
}

rc=0

while read -r local_ref local_sha remote_ref remote_sha; do
	# Skip ref deletions: no pushed commit to inspect.
	[ -z "${local_sha//0/}" ] && continue

	base=$(resolve_base "$remote_sha" "$local_sha")

	while read -r lang; do
		po="po/$lang.po"
		# Skip languages whose catalog is absent at the pushed commit.
		git cat-file -e "$local_sha:$po" 2>/dev/null || continue
		if ! out=$(scripts/trans-delta.sh "$base" --tip "$local_sha" "$po"); then
			printf '%s\n' "$out"
			rc=1
		fi
	done < <(linguas)
done

if [ "$rc" -ne 0 ]; then
	echo ""
	echo "❌ Pre-push validation failed"
	echo ""
	echo "This push introduces new fuzzy or untranslated catalog entries."
	echo "Translate or resolve the entries listed above, commit the updated"
	echo "po/ catalogs, and push again."
	echo ""
	echo "If you have determined this push must proceed anyway:"
	echo ""
	echo "  FORCE_PUSH=true git push"
	echo ""
	exit 1
fi

exit 0
