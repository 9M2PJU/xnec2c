#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"Використання: xnec2c [параметри] [<ім'я-вхідного-файлу>]\n"
"  -i|--input         <ім'я-вхідного-файлу>\n"
"  -c|--config        <шлях-до-файлу-конфігурації>     - файл повинен "
"існувати\n"
"  -C|--new-config    <шлях-до-нового-файлу-конфігурації> - створює файл, "
"якщо він відсутній\n"
"  -j|--jobs  <кількість процесорів у SMP-машині> (-j0 вимикає розгалуження)\n"
"     --openblas-threads <n>  встановити кількість потоків OpenBLAS (за "
"замовчуванням: 1)\n"
"     --mkl-threads <n>       встановити кількість потоків Intel MKL (за "
"замовчуванням: 1)\n"
"     --omp-threads <n>       встановити кількість потоків OpenMP (за "
"замовчуванням: 1)\n"
"  -b|--batch:        увімкнути пакетний режим, вийти після завершення циклу "
"частот\n"
"  -P|--no-pthreads:  вимкнути pthreads і використовувати цикл GTK для "
"налагодження\n"
"  -h|--help:         вивести інформацію про використання і вийти\n"
"  -V|--version:      вивести номер версії xnec2c і вийти\n"
"  -v|--verbose:      збільшити детальність, можна вказати кілька разів\n"
"  -d|--debug:        увімкнути налагоджувальний вивід (-dd включає "
"трасування стеку)\n"
"  -d|--quiet:        приховати налагоджувальний/детальний вивід\n"
"\n"
"  --optimize:        Негайно активувати оптимізатор.\n"
"  --skip-verify:     пропустити перевірку геометрії\n"
"  --mem-report:      звіт про живі байти керованого алокатора для кожного "
"місця виклику\n"
"\n"
"Наступні аргументи записують у вихідний файл після завершення циклу частот.\n"
"Їх зручно поєднувати з --batch; якщо ви хочете вказати імена файлів для\n"
"запису без режиму --batch, увімкніть Файл->Налаштування оптимізатора,\n"
"інакше вказані вами в командному рядку файли не будуть записані.\n"
"\n"
"  --write-csv             <ім'я-файлу>  - записати CSV-файл вимірювань\n"
"  --write-s1p             <ім'я-файлу>  - записати S1P-файл S-параметрів\n"
"  --write-s2p-max-gain    <ім'я-файлу>  - записати S2P-файл, порт-2 — "
"максимальне підсилення\n"
"  --write-s2p-viewer-gain <ім'я-файлу>  - записати S2P-файл, порт-2 — "
"підсилення спостерігача\n"
"  --write-rdpat           <ім'я-файлу>  - записати CSV діаграми "
"випромінювання\n"
"  --write-currents        <ім'я-файлу>  - записати CSV струмів і зарядів\n"
"  --write-gnuplot-structure <ім'я-файлу> - записати файл структури gnuplot\n"
"  --write-patch-currents  <ім'я-файлу>  - записати CSV поверхневих струмів "
"патчів\n"
"  --write-validation-dir <директорія> - записати повне дерево даних "
"перевірки\n"

