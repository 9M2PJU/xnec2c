#: src/utils.c:45
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"उपयोग: xnec2c [विकल्प] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - फ़ाइल मौजूद होनी चाहिए\n"
"  -C|--new-config    <new-config-file-path> - गायब होने पर फ़ाइल बनाता है\n"
"  -j|--jobs  <SMP मशीन में प्रोसेसर की संख्या> (-j0 forking अक्षम करता है)\n"
"     --openblas-threads <n>  OpenBLAS थ्रेड संख्या सेट करें (डिफ़ॉल्ट: 1)\n"
"     --mkl-threads <n>       Intel MKL थ्रेड संख्या सेट करें (डिफ़ॉल्ट: 1)\n"
"     --omp-threads <n>       OpenMP थ्रेड संख्या सेट करें (डिफ़ॉल्ट: 1)\n"
"  -b|--batch:        बैच मोड सक्षम करें, आवृत्ति लूप चलने के बाद बाहर निकलें\n"
"  -P|--no-pthreads:  डिबगिंग के लिए pthreads अक्षम करें और GTK लूप का उपयोग करें\n"
"  -h|--help:         उपयोग जानकारी प्रिंट करें और बाहर निकलें\n"
"  -V|--version:      xnec2c संस्करण संख्या प्रिंट करें और बाहर निकलें\n"
"  -v|--verbose:      वर्बोसिटी बढ़ाएं, कई बार निर्दिष्ट किया जा सकता है\n"
"  -d|--debug:        डिबग आउटपुट सक्षम करें (-dd में बैकट्रेस शामिल हैं)\n"
"  -d|--quiet:        डिबग/वर्बोस आउटपुट दबाएं\n"
"\n"
"  --optimize:        ऑप्टिमाइज़र को तुरंत सक्रिय करें।\n"
"  --skip-verify:     ज्यामिति सत्यापन जाँच छोड़ें\n"
"\n"
"निम्नलिखित आर्गुमेंट आवृत्ति लूप पूरा होने के बाद आउटपुट फ़ाइल में लिखते हैं।\n"
"ये --batch के साथ संयोजन में उपयोगी हैं; यदि आप --batch मोड के बिना\n"
"लिखने के लिए फ़ाइलनाम निर्दिष्ट करना चाहते हैं तो File->Optimizer\n"
"Settings सक्षम करें अन्यथा कमांड लाइन पर निर्दिष्ट फ़ाइलें नहीं लिखी जाएंगी।\n"
"\n"
"  --write-csv             <filename>  - माप की CSV फ़ाइल लिखें\n"
"  --write-s1p             <filename>  - S-parameters की S1P फ़ाइल लिखें\n"
"  --write-s2p-max-gain    <filename>  - S2P फ़ाइल लिखें, port-2 max-gain है\n"
"  --write-s2p-viewer-gain <filename>  - S2P फ़ाइल लिखें, port-2 viewer-gain है\n"
"  --write-rdpat           <filename>  - विकिरण प्रतिरूप की CSV लिखें\n"
"  --write-currents        <filename>  - धाराओं और आवेशों की CSV लिखें\n"
"  --write-gnuplot-structure <filename> - gnuplot संरचना फ़ाइल लिखें\n"
"  --write-patch-currents  <filename>  - patch सरफेस धाराओं की CSV लिखें\n"

