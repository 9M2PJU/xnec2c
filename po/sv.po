#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"Användning: xnec2c [alternativ] [<indatafilnamn>]\n"
"  -i|--input         <indatafilnamn>\n"
"  -c|--config        <konfigurationsfilsökväg>     - filen måste finnas\n"
"  -C|--new-config    <ny-konfigurationsfilsökväg> - skapar filen om den "
"saknas\n"
"  -j|--jobs  <antal processorer i SMP-maskin> (-j0 inaktiverar forking)\n"
"     --openblas-threads <n>  ange OpenBLAS-trådantal (standard: 1)\n"
"     --mkl-threads <n>       ange Intel MKL-trådantal (standard: 1)\n"
"     --omp-threads <n>       ange OpenMP-trådantal (standard: 1)\n"
"  -b|--batch:        aktivera batchläge, avsluta efter frekvensslingan körs\n"
"  -P|--no-pthreads:  inaktivera pthreads och använd GTK-loopen för "
"felsökning\n"
"  -h|--help:         visa användningsinformation och avsluta\n"
"  -V|--version:      visa xnec2c-versionsnummer och avsluta\n"
"  -v|--verbose:      öka utförlighet, kan anges flera gånger\n"
"  -d|--debug:        aktivera felsökningsutdata (-dd inkluderar "
"bakåtspårningar)\n"
"  -d|--quiet:        undertryck felsöknings-/utförlig utdata\n"
"\n"
"  --optimize:        Aktivera optimeraren omedelbart.\n"
"  --skip-verify:     hoppa över geometriverifieringskontroller\n"
"  --mem-report:      rapport om hanterad allokators aktiva byte per "
"anropsplats\n"
"\n"
"Följande argument skriver till en utdatafil efter att frekvensslingan\n"
"har slutförts. Dessa är användbara att kombinera med --batch; Om du vill "
"ange\n"
"filnamn att skriva utan --batchläge, aktivera Arkiv->Optimerarinställningar\n"
"annars kommer filerna du anger på kommandoraden inte att skrivas.\n"
"\n"
"  --write-csv             <filnamn>  - skriv CSV-fil med mätningar\n"
"  --write-s1p             <filnamn>  - skriv S1P-fil med S-parametrar\n"
"  --write-s2p-max-gain    <filnamn>  - skriv S2P-fil, port-2 är "
"maxförstärkning\n"
"  --write-s2p-viewer-gain <filnamn>  - skriv S2P-fil, port-2 är "
"betraktarförstärkning\n"
"  --write-rdpat           <filnamn>  - skriv CSV av strålningsmönstret\n"
"  --write-currents        <filnamn>  - skriv CSV av strömmar och laddningar\n"
"  --write-gnuplot-structure <filnamn> - skriv gnuplot-strukturfil\n"
"  --write-patch-currents  <filnamn>  - skriv CSV av patchytströmmar\n"

