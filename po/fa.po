#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"راهنمای استفاده: xnec2c [گزینه‌ها] [<نام-فایل-ورودی>]\n"
"  -i|--input         <نام-فایل-ورودی>\n"
"  -c|--config        <مسیر-فایل-پیکربندی>     - فایل باید وجود داشته باشد\n"
"  -C|--new-config    <مسیر-فایل-پیکربندی-جدید> - فایل را در صورت نبود ایجاد "
"می‌کند\n"
"  -j|--jobs  <تعداد پردازنده‌ها در دستگاه SMP> (-j0 fork کردن را غیرفعال "
"می‌کند)\n"
"     --openblas-threads <n>  تنظیم تعداد رشته‌های OpenBLAS (پیش‌فرض: 1)\n"
"     --mkl-threads <n>       تنظیم تعداد رشته‌های Intel MKL (پیش‌فرض: 1)\n"
"     --omp-threads <n>       تنظیم تعداد رشته‌های OpenMP (پیش‌فرض: 1)\n"
"  -b|--batch:        فعال‌سازی حالت دسته‌ای، خروج پس از اجرای حلقه فرکانس\n"
"  -P|--no-pthreads:  غیرفعال‌سازی pthreads و استفاده از حلقه GTK برای "
"اشکال‌زدایی\n"
"  -h|--help:         نمایش اطلاعات راهنما و خروج\n"
"  -V|--version:      نمایش شماره نسخه xnec2c و خروج\n"
"  -v|--verbose:      افزایش پرگویی، می‌توان چندبار مشخص کرد\n"
"  -d|--debug:        فعال‌سازی خروجی اشکال‌زدایی (-dd شامل ردیابی پشته)\n"
"  -d|--quiet:        سرکوب خروجی اشکال‌زدایی/پرگویی\n"
"\n"
"  --optimize:        فعال‌سازی فوری بهینه‌ساز.\n"
"  --skip-verify:     رد کردن بررسی‌های تأیید هندسه\n"
"  --mem-report:      گزارش بایت‌های زنده تخصیص‌دهنده مدیریت‌شده به ازای هر محل "
"فراخوانی\n"
"\n"
"آرگومان‌های زیر پس از اتمام حلقه فرکانس در فایل خروجی می‌نویسند.\n"
"این‌ها برای ترکیب با --batch مفیدند؛ اگر می‌خواهید نام فایل‌ها را بدون\n"
"--batch مشخص کنید، «فایل→تنظیمات بهینه‌ساز» را فعال کنید وگرنه فایل‌های\n"
"مشخص‌شده در خط فرمان نوشته نخواهند شد.\n"
"\n"
"  --write-csv             <نام‌فایل>  - نوشتن فایل CSV اندازه‌گیری‌ها\n"
"  --write-s1p             <نام‌فایل>  - نوشتن فایل S1P پارامترهای S\n"
"  --write-s2p-max-gain    <نام‌فایل>  - نوشتن فایل S2P، پورت 2 حداکثر بهره\n"
"  --write-s2p-viewer-gain <نام‌فایل>  - نوشتن فایل S2P، پورت 2 بهره بیننده\n"
"  --write-rdpat           <نام‌فایل>  - نوشتن CSV الگوی تشعشع\n"
"  --write-currents        <نام‌فایل>  - نوشتن CSV جریان‌ها و بارها\n"
"  --write-gnuplot-structure <نام‌فایل> - نوشتن فایل ساختار gnuplot\n"
"  --write-patch-currents  <نام‌فایل>  - نوشتن CSV جریان‌های سطح پچ\n"
"  --write-validation-dir <پوشه> - نوشتن درخت کامل داده‌های صحه‌گذاری\n"

