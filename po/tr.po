#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"Kullanım: xnec2c [seçenekler] [<girdi-dosya-adı>]\n"
"  -i|--input         <girdi-dosya-adı>\n"
"  -c|--config        <yapılandırma-dosya-yolu>     - dosya mevcut olmalı\n"
"  -C|--new-config    <yeni-yapılandırma-dosya-yolu> - eksikse dosyayı "
"oluşturur\n"
"  -j|--jobs  <SMP makinesindeki işlemci sayısı> (-j0 çatallamayı devre dışı "
"bırakır)\n"
"     --openblas-threads <n>  OpenBLAS iş parçacığı sayısını ayarla "
"(varsayılan: 1)\n"
"     --mkl-threads <n>       Intel MKL iş parçacığı sayısını ayarla "
"(varsayılan: 1)\n"
"     --omp-threads <n>       OpenMP iş parçacığı sayısını ayarla "
"(varsayılan: 1)\n"
"  -b|--batch:        toplu iş modunu etkinleştir, frekans döngüsü "
"çalıştıktan sonra çık\n"
"  -P|--no-pthreads:  pthreads'i devre dışı bırak ve hata ayıklama için GTK "
"döngüsünü kullan\n"
"  -h|--help:         kullanım bilgisini yazdır ve çık\n"
"  -V|--version:      xnec2c sürüm numarasını yazdır ve çık\n"
"  -v|--verbose:      ayrıntı düzeyini artır, birden fazla kez "
"belirtilebilir\n"
"  -d|--debug:        hata ayıklama çıktısını etkinleştir (-dd geri "
"izlemeleri içerir)\n"
"  -d|--quiet:        hata ayıklama/ayrıntılı çıktıyı bastır\n"
"\n"
"  --optimize:        Optimize ediciyi hemen etkinleştir.\n"
"  --skip-verify:     geometri doğrulama kontrollerini atla\n"
"  --mem-report:      yönetilen tahsis alanındaki canlı baytları çağrı "
"noktasına göre raporla\n"
"\n"
"Aşağıdaki argümanlar frekans döngüsü tamamlandıktan sonra bir çıktı "
"dosyasına\n"
"yazar.  Bunlar --batch ile birleştirmek için yararlıdır; --batch modu "
"olmadan\n"
"dosya adları belirtmek istiyorsanız Dosya->Optimize Edici Ayarları'nı\n"
"etkinleştirin, aksi takdirde komut satırında belirttiğiniz dosyalar "
"yazılmayacaktır.\n"
"\n"
"  --write-csv             <dosyaadı>  - ölçümlerin CSV dosyasını yaz\n"
"  --write-s1p             <dosyaadı>  - S-parametrelerinin S1P dosyasını "
"yaz\n"
"  --write-s2p-max-gain    <dosyaadı>  - S2P dosyası yaz, port-2 maksimum "
"kazanç\n"
"  --write-s2p-viewer-gain <dosyaadı>  - S2P dosyası yaz, port-2 "
"görüntüleyici kazancı\n"
"  --write-rdpat           <dosyaadı>  - ışınım örüntüsünün CSV'sini yaz\n"
"  --write-currents        <dosyaadı>  - akımlar ve yüklerin CSV'sini yaz\n"
"  --write-gnuplot-structure <dosyaadı> - gnuplot yapı dosyasını yaz\n"
"  --write-patch-currents  <dosyaadı>  - yama yüzey akımlarının CSV'sini yaz\n"
"  --write-validation-dir <dizin> - tam doğrulama veri ağacını yaz\n"

