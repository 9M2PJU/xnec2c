#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"Foydalanish: xnec2c [parametrlar] [<kirish-fayl-nomi>]\n"
"  -i|--input         <kirish-fayl-nomi>\n"
"  -c|--config        <konfiguratsiya-fayl-yoli>     - fayl mavjud boʻlishi "
"kerak\n"
"  -C|--new-config    <yangi-konfiguratsiya-fayl-yoli> - yoʻq boʻlsa "
"yaratadi\n"
"  -j|--jobs  <SMP mashinasidagi protsessorlar soni> (-j0 forkni oʻchiradi)\n"
"     --openblas-threads <n>  OpenBLAS ip sonini belgilash (standart: 1)\n"
"     --mkl-threads <n>       Intel MKL ip sonini belgilash (standart: 1)\n"
"     --omp-threads <n>       OpenMP ip sonini belgilash (standart: 1)\n"
"  -b|--batch:        paketli rejimni yoqish, chastota tsikli tugagach "
"chiqish\n"
"  -P|--no-pthreads:  pthreadsni oʻchirish va nosozlik tuzatish uchun GTK "
"tsikldan foydalanish\n"
"  -h|--help:         foydalanish maʼlumotlarini chiqarish va chiqish\n"
"  -V|--version:      xnec2c versiya raqamini chiqarish va chiqish\n"
"  -v|--verbose:      tafsilotlilikni oshirish, bir necha marta belgilanishi "
"mumkin\n"
"  -d|--debug:        nosozlik tuzatish chiqishini yoqish (-dd orqa izlarni "
"oʻz ichiga oladi)\n"
"  -d|--quiet:        nosozlik tuzatish/tafsilotli chiqishni yashirish\n"
"\n"
"  --optimize:        Optimallashtiruvchini darhol faollashtirish.\n"
"  --skip-verify:     geometriya tekshiruvlarini oʻtkazib yuborish\n"
"  --mem-report:      har bir chaqiruv joyidagi boshqariladigan ajratuvchi "
"baytlarini bildirish\n"
"\n"
"Quyidagi argumentlar chastota tsikli tugagandan soʻng chiqish fayliga "
"yozadi.\n"
"Bular --batch bilan birlashtirishda foydali; Agar --batch rejimisiz\n"
"fayl nomlarini belgilashni xohlasangiz, File->Optimizer\n"
"Settings ni yoqing, aks holda buyruq satrida belgilangan fayllar "
"yozilmaydi.\n"
"\n"
"  --write-csv             <fayl-nomi>  - oʻlchov CSV faylini yozish\n"
"  --write-s1p             <fayl-nomi>  - S-parametrlar S1P faylini yozish\n"
"  --write-s2p-max-gain    <fayl-nomi>  - S2P fayli yozish, port-2 maks-"
"kuchaytirish\n"
"  --write-s2p-viewer-gain <fayl-nomi>  - S2P fayli yozish, port-2 koʻruvchi-"
"kuchaytirish\n"
"  --write-rdpat           <fayl-nomi>  - nurlanish diagrammasi CSV ni "
"yozish\n"
"  --write-currents        <fayl-nomi>  - toklar va zaryadlar CSV ni yozish\n"
"  --write-gnuplot-structure <fayl-nomi> - gnuplot tuzilma faylini yozish\n"
"  --write-patch-currents  <fayl-nomi>  - patch sirt toklari CSV ni yozish\n"
"  --write-validation-dir <katalog> - toʻliq tekshiruv maʼlumotlar daraxtini "
"yozish\n"

