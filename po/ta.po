#: src/geometry.c:1459
#, c-format
msgid ""
"tag=%d/seg=%d: endpoint distance=%.3e is too close (below connection "
"threshold=%.3e); segment will connect to itself\n"
msgstr ""
"tag=%d/seg=%d: முனைப்புள்ளித் தூரம்=%.3e மிக அருகில் உள்ளது (இணைப்பு வரம்பு=%.3e "
"க்குக் கீழே); பிரிவு தன்னுடன் தானே இணையும்\n"

#: src/geometry.c:1464
#, c-format
msgid "tag=%d: suppressing additional self-connection warnings\n"
msgstr "tag=%d: கூடுதல் சுய-இணைப்பு எச்சரிக்கைகளை அடக்குகிறது\n"

#: src/geometry.c:1514
#, c-format
msgid ""
"tag=%d/seg=%d: distance=%.3e to tag=%d/seg=%d closer than 2x connection "
"threshold %.3e; unintended connections possible\n"
msgstr ""
"tag=%1$d/seg=%2$d: tag=%4$d/seg=%5$d க்கான தூரம்=%3$.3e இணைப்பு வரம்பு %6$.3e இன் "
"2 மடங்கை விட அருகில் உள்ளது; உத்தேசிக்காத இணைப்புகள் சாத்தியம்\n"

#: src/geometry.c:1520
#, c-format
msgid "tag=%d: suppressing additional overlap warnings\n"
msgstr "tag=%d: கூடுதல் மேலெழுதல் எச்சரிக்கைகளை அடக்குகிறது\n"

#: src/geometry.c:1589
#, c-format
msgid ""
"tag=%d/seg=%d: length=%.3e is too short (and close enough) to tag=%d/seg=%d "
"length=%.3e that connection detection may fail or short\n"
msgstr ""
"tag=%d/seg=%d: நீளம்=%.3e மிகக் குறுகியது (மற்றும் tag=%d/seg=%d நீளம்=%.3e க்கு "
"போதுமான அளவு அருகில்) உள்ளதால் இணைப்புக் கண்டறிதல் தோல்வியடையலாம் அல்லது குறுக்கலாம்\n"

#: src/geometry.c:1595
#, c-format
msgid ""
"tag=%d: suppressing additional connection detection may fail or short "
"warnings\n"
msgstr ""
"tag=%d: இணைப்புக் கண்டறிதல் தோல்வி அல்லது குறுக்கல் தொடர்பான கூடுதல் எச்சரிக்கைகளை "
"அடக்குகிறது\n"

#: src/geometry.c:1628
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f < 0.001; similarity of "
"current components leads to numerical inaccuracies (min=0.001, fine=0.05, "
"recommended <= 0.1)\n"
msgstr ""
"tag=%d/seg=%d: நீளம்/அலைநீள விகிதம் %.3f < 0.001; மின்னோட்ட கூறுகளின் ஒற்றுமை எண் "
"துல்லியமின்மைக்கு வழிவகுக்கும் (min=0.001, fine=0.05, recommended <= 0.1)\n"

#: src/geometry.c:1633
#, c-format
msgid "tag=%d: suppressing additional short wavelength ratio errors\n"
msgstr "tag=%d: குறு அலைநீள விகிதப் பிழைகளின் கூடுதல் எச்சரிக்கைகளை அடக்குகிறது\n"

#: src/geometry.c:1647
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.1; current sampling "
"resolution limited by segment spacing (min=0.001, fine=0.05, recommended <= "
