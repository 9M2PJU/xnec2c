msgstr "tag=%d: 추가 짧은 파장 비율 오류를 표시하지 않습니다\n"

#: src/geometry.c:1647
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.1; current sampling "
