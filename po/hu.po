msgid ""
"The frequency loop is running\n"
"Are you sure you wish to close this window?"
msgstr ""
"A frekvenciahurok fut\n"
"Biztos benne, hogy bezárja ezt az ablakot?"

#: src/callback_func.c:514
#, c-format
msgid ""
"Frequency plots window closed: excitation type %d is incompatible.\n"
"Use type 0 (Applied E Field) or 5 (Current Discontinuity) instead."
msgstr ""
"A frekvenciaábrák ablaka bezárva: a(z) %d gerjesztési típus nem "
"kompatibilis.\n"
"Használjon helyette 0-s típust (alkalmazott E mező) vagy 5-ös típust "
"(áramdiszkontinuitás)."

#: src/callback_func.c:520
#, c-format
msgid ""
"Frequency plots are not available with excitation type %d.\n"
"This model uses Incident Field or Elementary Current Source excitation.\n"
"Change the EX card to type 0 (Applied E Field) or 5 (Current Discontinuity)."
msgstr ""
"A frekvenciaábrák nem érhetők el a(z) %d gerjesztési típussal.\n"
"Ez a modell beeső mezőt vagy elemi áramforrás gerjesztést használ.\n"
"Módosítsa az EX kártyát 0-s típusra (alkalmazott E mező) vagy 5-ös típusra "
"(áramdiszkontinuitás)."

