#: src/callback_func.c:263
msgid ""
"The frequency loop is running\n"
"Are you sure you wish to end the calculation?"
msgstr ""
"La boucle de fréquence est en cours d'exécution\n"
"Êtes-vous sûr de vouloir arrêter le calcul ?"

#: src/callback_func.c:267
msgid ""
"The frequency loop is running\n"
"Are you sure you wish to close this window?"
msgstr ""
"La boucle de fréquence est en cours d'exécution\n"
"Êtes-vous sûr de vouloir fermer cette fenêtre ?"

#: src/callback_func.c:514
#, c-format
msgid ""
"Frequency plots window closed: excitation type %d is incompatible.\n"
"Use type 0 (Applied E Field) or 5 (Current Discontinuity) instead."
msgstr ""
"Fenêtre des graphiques de fréquence fermée : le type d'excitation %d est "
"incompatible.\n"
"Utilisez le type 0 (champ E appliqué) ou 5 (discontinuité de courant) à la "
"place."

#: src/callback_func.c:520
#, c-format
msgid ""
"Frequency plots are not available with excitation type %d.\n"
"This model uses Incident Field or Elementary Current Source excitation.\n"
"Change the EX card to type 0 (Applied E Field) or 5 (Current Discontinuity)."
msgstr ""
"Les graphiques de fréquence ne sont pas disponibles avec le type "
"d'excitation %d.\n"
"Ce modèle utilise une excitation par champ incident ou source de courant "
"élémentaire.\n"
"Modifiez la carte EX vers le type 0 (champ E appliqué) ou 5 (discontinuité "
"de courant)."

