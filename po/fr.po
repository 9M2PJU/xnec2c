msgid ""
"A new NEC2 input file may not be created\n"
"while the Frequency Loop is running"
msgstr ""
"Un nouveau fichier d'entrée NEC2 ne peut pas être créé\n"
"pendant l'exécution de la boucle de fréquence"

#: src/callbacks.c:300
