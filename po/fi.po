#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"Käyttö: xnec2c [valitsimet] [<syötetiedoston-nimi>]\n"
"  -i|--input         <syötetiedoston-nimi>\n"
"  -c|--config        <asetustiedoston-polku>     - tiedoston on oltava "
"olemassa\n"
"  -C|--new-config    <uuden-asetustiedoston-polku> - luo tiedoston, jos se "
"puuttuu\n"
"  -j|--jobs  <prosessorien määrä SMP-koneessa> (-j0 poistaa haaroituksen "
"käytöstä)\n"
"     --openblas-threads <n>  aseta OpenBLAS-säikeiden määrä (oletus: 1)\n"
"     --mkl-threads <n>       aseta Intel MKL -säikeiden määrä (oletus: 1)\n"
"     --omp-threads <n>       aseta OpenMP-säikeiden määrä (oletus: 1)\n"
"  -b|--batch:        ota erätila käyttöön, lopeta taajuussilmukan jälkeen\n"
"  -P|--no-pthreads:  poista pthreads käytöstä ja käytä GTK-silmukkaa "
"virheenkorjaukseen\n"
"  -h|--help:         tulosta käyttöohjeet ja lopeta\n"
"  -V|--version:      tulosta xnec2c:n versionumero ja lopeta\n"
"  -v|--verbose:      lisää yksityiskohtaisuutta, voidaan määrittää useita "
"kertoja\n"
"  -d|--debug:        ota virheenkorjaustulostus käyttöön (-dd sisältää "
"pinojäljitykset)\n"
"  -d|--quiet:        estä virheenkorjaus-/yksityiskohtainen tulostus\n"
"\n"
"  --optimize:        Aktivoi optimoija välittömästi.\n"
"  --skip-verify:     ohita geometrian tarkistukset\n"
"  --mem-report:      raportoi hallitun allokaattorin elossa olevat tavut "
"kutsupaikkaa kohti\n"
"\n"
"Seuraavat argumentit kirjoittavat tulostiedostoon taajuussilmukan\n"
"valmistuttua. Nämä ovat hyödyllisiä yhdessä --batch-tilan kanssa. Jos "
"haluat\n"
"määrittää tiedostonimet ilman --batch-tilaa, ota käyttöön Tiedosto-"
">Optimoijan\n"
"asetukset, muuten komentorivillä määritettyjä tiedostoja ei kirjoiteta.\n"
"\n"
"  --write-csv             <tiedostonimi>  - kirjoita mittausten CSV-"
"tiedosto\n"
"  --write-s1p             <tiedostonimi>  - kirjoita S-parametrien S1P-"
"tiedosto\n"
"  --write-s2p-max-gain    <tiedostonimi>  - kirjoita S2P-tiedosto, portti 2 "
"on maksimivahvistus\n"
"  --write-s2p-viewer-gain <tiedostonimi>  - kirjoita S2P-tiedosto, portti 2 "
"on katseluvahvistus\n"
"  --write-rdpat           <tiedostonimi>  - kirjoita säteilykuvion CSV-"
"tiedosto\n"
"  --write-currents        <tiedostonimi>  - kirjoita virtojen ja varausten "
"CSV-tiedosto\n"
"  --write-gnuplot-structure <tiedostonimi> - kirjoita gnuplot-"
"rakennetiedosto\n"
"  --write-patch-currents  <tiedostonimi>  - kirjoita pintavirtojen CSV-"
"tiedosto\n"
"  --write-validation-dir <hakemisto> - kirjoita koko validointitietopuu\n"

