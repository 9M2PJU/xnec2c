#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"استعمال: xnec2c [اختیارات] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - فائل موجود ہونی چاہیے\n"
"  -C|--new-config    <new-config-file-path> - غیر موجود ہونے پر فائل بناتا "
"ہے\n"
"  -j|--jobs  <SMP مشین میں پروسیسرز کی تعداد> (-j0 فورکنگ غیر فعال کرتا ہے)\n"
"     --openblas-threads <n>  OpenBLAS تھریڈ کی تعداد مقرر کریں (ڈیفالٹ: 1)\n"
"     --mkl-threads <n>       Intel MKL تھریڈ کی تعداد مقرر کریں (ڈیفالٹ: 1)\n"
"     --omp-threads <n>       OpenMP تھریڈ کی تعداد مقرر کریں (ڈیفالٹ: 1)\n"
"  -b|--batch:        بیچ موڈ فعال کریں، فریکوئنسی لوپ چلنے کے بعد باہر "
"نکلیں\n"
"  -P|--no-pthreads:  pthreads غیر فعال کریں اور ڈیبگنگ کے لیے GTK لوپ "
"استعمال کریں\n"
"  -h|--help:         استعمال کی معلومات دکھائیں اور باہر نکلیں\n"
"  -V|--version:      xnec2c ورژن نمبر دکھائیں اور باہر نکلیں\n"
"  -v|--verbose:      تفصیل بڑھائیں، متعدد بار استعمال کیا جا سکتا ہے\n"
"  -d|--debug:        ڈیبگ آؤٹ پٹ فعال کریں (-dd بیک ٹریسز شامل کرتا ہے)\n"
"  -d|--quiet:        ڈیبگ/تفصیلی آؤٹ پٹ دبائیں\n"
"\n"
"  --optimize:        آپٹیمائزر فوری طور پر فعال کریں۔\n"
"  --skip-verify:     جیومیٹری تصدیقی جانچ چھوڑیں\n"
"\n"
"درج ذیل آرگومنٹس فریکوئنسی لوپ مکمل ہونے کے بعد آؤٹ پٹ فائل میں لکھتے ہیں۔\n"
"یہ --batch کے ساتھ استعمال کے لیے مفید ہیں؛ اگر آپ --batch موڈ کے بغیر\n"
"فائل نام لکھنا چاہتے ہیں تو File->Optimizer Settings فعال کریں ورنہ\n"
"کمانڈ لائن پر بیان کردہ فائلیں نہیں لکھی جائیں گی۔\n"
"\n"
"  --write-csv             <filename>  - پیمائش کی CSV فائل لکھیں\n"
"  --write-s1p             <filename>  - S-parameters کی S1P فائل لکھیں\n"
"  --write-s2p-max-gain    <filename>  - S2P فائل لکھیں، port-2 max-gain ہے\n"
"  --write-s2p-viewer-gain <filename>  - S2P فائل لکھیں، port-2 viewer-gain "
"ہے\n"
"  --write-rdpat           <filename>  - ریڈی ایشن پیٹرن کی CSV لکھیں\n"
"  --write-currents        <filename>  - کرنٹس اور چارجز کی CSV لکھیں\n"
"  --write-gnuplot-structure <filename> - gnuplot سٹرکچر فائل لکھیں\n"
"  --write-patch-currents  <filename>  - پیچ سرفیس کرنٹس کی CSV لکھیں\n"

