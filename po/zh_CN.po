msgstr ""
"tag=%d/seg=%d：长度/半径比 %.1f < 2.0；标准细导线核场误差大幅超过 1%%（最小"
"=2.0，1%%精确=8.0）\n"

#: src/geometry.c:1707
#, c-format
msgid "tag=%d: suppressing additional standard kernel ratio errors\n"
msgstr "tag=%d：抑制更多标准核比率错误\n"

#: src/geometry.c:1721
#, c-format
msgid ""
"tag=%d/seg=%d: length/radius ratio of %.1f < 8.0; standard thin-wire kernel "
