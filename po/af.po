#: src/callback_func.c:520
#, c-format
msgid ""
"Frequency plots window closed: excitation type %d is incompatible.\n"
"Use type 0 (Applied E Field) or 5 (Current Discontinuity) instead."
msgstr ""
"Frekwensiegrafieke-venster gesluit: opwekkingstipe %d is onversoenbaar.\n"
"Gebruik tipe 0 (Toegepaste E-veld) of 5 (Stroomdiskontinuïteit) in plaas "
"daarvan."

#: src/callback_func.c:526
#, c-format
msgid ""
"Frequency plots are not available with excitation type %d.\n"
"This model uses Incident Field or Elementary Current Source excitation.\n"
"Change the EX card to type 0 (Applied E Field) or 5 (Current Discontinuity)."
msgstr ""
"Frekwensiegrafieke is nie beskikbaar met opwekkingstipe %d nie.\n"
"Hierdie model gebruik Invalsveld of Elementêre Stroombron opwekking.\n"
"Verander die EX-kaart na tipe 0 (Toegepaste E-veld) of 5 "
"(Stroomdiskontinuïteit)."

