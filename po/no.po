#: src/callback_func.c:523
#, c-format
msgid ""
"Frequency plots window closed: excitation type %d is incompatible.\n"
"Use type 0 (Applied E Field) or 5 (Current Discontinuity) instead."
msgstr ""
"Frekvensplottvindu lukket: eksitasjonstype %d er inkompatibel.\n"
"Bruk type 0 (Applied E Field) eller 5 (Current Discontinuity) i stedet."

#: src/callback_func.c:529
#, c-format
msgid ""
"Frequency plots are not available with excitation type %d.\n"
"This model uses Incident Field or Elementary Current Source excitation.\n"
"Change the EX card to type 0 (Applied E Field) or 5 (Current Discontinuity)."
msgstr ""
"Frekvensplott er ikke tilgjengelig med eksitasjonstype %d.\n"
"Denne modellen bruker Incident Field- eller Elementary Current Source-"
"eksitasjon.\n"
"Endre EX-kortet til type 0 (Applied E Field) eller 5 (Current Discontinuity)."

