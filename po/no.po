#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"Bruk: xnec2c [alternativer] [<inndatafil-navn>]\n"
"  -i|--input         <inndatafil-navn>\n"
"  -c|--config        <konfigurasjonsfil-sti>     - filen må eksistere\n"
"  -C|--new-config    <ny-konfigurasjonsfil-sti> - oppretter filen hvis den "
"mangler\n"
"  -j|--jobs  <antall prosessorer i SMP-maskin> (-j0 deaktiverer forking)\n"
"     --openblas-threads <n>  angi OpenBLAS-trådantall (standard: 1)\n"
"     --mkl-threads <n>       angi Intel MKL-trådantall (standard: 1)\n"
"     --omp-threads <n>       angi OpenMP-trådantall (standard: 1)\n"
"  -b|--batch:        aktiver batch-modus, avslutt etter frekvenssløyfen "
"kjører\n"
"  -P|--no-pthreads:  deaktiver pthreads og bruk GTK-løkken for feilsøking\n"
"  -h|--help:         skriv ut bruksinformasjon og avslutt\n"
"  -V|--version:      skriv ut xnec2c-versjonsnummer og avslutt\n"
"  -v|--verbose:      øk detaljeringsgrad, kan angis flere ganger\n"
"  -d|--debug:        aktiver feilsøkingsutdata (-dd inkluderer "
"tilbakesporing)\n"
"  -d|--quiet:        undertrykk feilsøkings-/detaljert utdata\n"
"\n"
"  --optimize:        Aktiver optimalisatoren umiddelbart.\n"
"  --skip-verify:     hopp over geometriverifiseringskontroller\n"
"  --mem-report:      rapporter administrert allokator-byte per kallsted\n"
"\n"
"Følgende argumenter skriver til en utdatafil etter at frekvenssløyfen\n"
"fullføres. Disse er nyttige å kombinere med --batch; Hvis du ønsker å angi\n"
"filnavn for skriving uten --batch-modus, aktiver Fil-"
">Optimalisatorinnstillinger\n"
"eller filene du angir på kommandolinjen vil ikke bli skrevet.\n"
"\n"
"  --write-csv             <filnavn>  - skriv CSV-fil med målinger\n"
"  --write-s1p             <filnavn>  - skriv S1P-fil med S-parametre\n"
"  --write-s2p-max-gain    <filnavn>  - skriv S2P-fil, port-2 er maks-"
"forsterkning\n"
"  --write-s2p-viewer-gain <filnavn>  - skriv S2P-fil, port-2 er "
"visningsforsterkning\n"
"  --write-rdpat           <filnavn>  - skriv CSV med strålingsdiagrammet\n"
"  --write-currents        <filnavn>  - skriv CSV med strømmer og ladninger\n"
"  --write-gnuplot-structure <filnavn> - skriv gnuplot-strukturfil\n"
"  --write-patch-currents  <filnavn>  - skriv CSV med patch-strømmer\n"
"  --write-validation-dir <katalog> - skriv full valideringsdatatre\n"

