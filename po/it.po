#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"Uso: xnec2c [opzioni] [<nome-file-input>]\n"
"  -i|--input         <nome-file-input>\n"
"  -c|--config        <percorso-file-config>     - il file deve esistere\n"
"  -C|--new-config    <percorso-nuovo-file-config> - crea il file se "
"mancante\n"
"  -j|--jobs  <numero di processori in macchina SMP> (-j0 disabilita il "
"forking)\n"
"     --openblas-threads <n>  imposta il numero di thread OpenBLAS "
"(predefinito: 1)\n"
"     --mkl-threads <n>       imposta il numero di thread Intel MKL "
"(predefinito: 1)\n"
"     --omp-threads <n>       imposta il numero di thread OpenMP "
"(predefinito: 1)\n"
"  -b|--batch:        abilita modalità batch, esce dopo l'esecuzione del "
"ciclo di frequenza\n"
"  -P|--no-pthreads:  disabilita pthreads e usa il ciclo GTK per il debug\n"
"  -h|--help:         stampa le informazioni di utilizzo ed esce\n"
"  -V|--version:      stampa il numero di versione di xnec2c ed esce\n"
"  -v|--verbose:      aumenta la verbosità, può essere specificato più volte\n"
"  -d|--debug:        abilita l'output di debug (-dd include i backtrace)\n"
"  -d|--quiet:        sopprimi l'output di debug/verbose\n"
"\n"
"  --optimize:        Attiva l'ottimizzatore immediatamente.\n"
"  --skip-verify:     salta i controlli di verifica della geometria\n"
"  --mem-report:      segnala i byte attivi dell'allocatore gestito per sito "
"di chiamata\n"
"\n"
"I seguenti argomenti scrivono su un file di output dopo il completamento "
"del\n"
"ciclo di frequenza. Sono utili da combinare con --batch; Se si desidera\n"
"specificare nomi di file da scrivere senza la modalità --batch, abilitare\n"
"File->Impostazioni di Ottimizzazione o i file specificati sulla riga di "
"comando\n"
"non verranno scritti.\n"
"\n"
"  --write-csv             <nomefile>  - scrivi file CSV delle misurazioni\n"
"  --write-s1p             <nomefile>  - scrivi file S1P dei parametri S\n"
"  --write-s2p-max-gain    <nomefile>  - scrivi file S2P, porta-2 è guadagno "
"massimo\n"
"  --write-s2p-viewer-gain <nomefile>  - scrivi file S2P, porta-2 è guadagno "
"visualizzatore\n"
"  --write-rdpat           <nomefile>  - scrivi CSV del diagramma di "
"radiazione\n"
"  --write-currents        <nomefile>  - scrivi CSV di correnti e cariche\n"
"  --write-gnuplot-structure <nomefile> - scrivi file struttura gnuplot\n"
"  --write-patch-currents  <nomefile>  - scrivi CSV di correnti patch di "
"superficie\n"
"  --write-validation-dir <directory> - scrivi l'intero albero di dati di "
"validazione\n"

