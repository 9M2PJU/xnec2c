#: src/utils.c:45
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"Penggunaan: xnec2c [opsi] [<nama-file-input>]\n"
"  -i|--input         <nama-file-input>\n"
"  -c|--config        <path-file-konfigurasi>     - file harus ada\n"
"  -C|--new-config    <path-file-konfigurasi-baru> - membuat file jika tidak "
"ada\n"
"  -j|--jobs  <jumlah prosesor di mesin SMP> (-j0 menonaktifkan forking)\n"
"     --openblas-threads <n>  atur jumlah thread OpenBLAS (default: 1)\n"
"     --mkl-threads <n>       atur jumlah thread Intel MKL (default: 1)\n"
"     --omp-threads <n>       atur jumlah thread OpenMP (default: 1)\n"
"  -b|--batch:        aktifkan mode batch, keluar setelah loop frekuensi "
"selesai\n"
"  -P|--no-pthreads:  nonaktifkan pthreads dan gunakan loop GTK untuk "
"debugging\n"
"  -h|--help:         tampilkan informasi penggunaan dan keluar\n"
"  -V|--version:      tampilkan nomor versi xnec2c dan keluar\n"
"  -v|--verbose:      tingkatkan verbositas, dapat ditentukan beberapa kali\n"
"  -d|--debug:        aktifkan output debug (-dd menyertakan backtrace)\n"
"  -d|--quiet:        sembunyikan output debug/verbose\n"
"\n"
"  --optimize:        Aktifkan optimizer segera.\n"
"  --skip-verify:     lewati pemeriksaan verifikasi geometri\n"
"\n"
"Argumen berikut menulis ke file output setelah loop frekuensi selesai.\n"
"Ini berguna untuk dikombinasikan dengan --batch; Jika Anda ingin menentukan\n"
"nama file untuk ditulis tanpa mode --batch maka aktifkan File->Pengaturan\n"
"Optimizer atau file yang Anda tentukan di baris perintah tidak akan "
"ditulis.\n"
"\n"
"  --write-csv             <namafile>  - tulis file CSV pengukuran\n"
"  --write-s1p             <namafile>  - tulis file S1P S-parameter\n"
"  --write-s2p-max-gain    <namafile>  - tulis file S2P, port-2 adalah max-"
"gain\n"
"  --write-s2p-viewer-gain <namafile>  - tulis file S2P, port-2 adalah viewer-"
"gain\n"
"  --write-rdpat           <namafile>  - tulis CSV pola radiasi\n"
"  --write-currents        <namafile>  - tulis CSV arus dan muatan\n"
"  --write-gnuplot-structure <namafile> - tulis file struktur gnuplot\n"
"  --write-patch-currents  <namafile>  - tulis CSV arus permukaan patch\n"

