#: src/callback_func.c:520
#, c-format
msgid ""
"Frequency plots window closed: excitation type %d is incompatible.\n"
"Use type 0 (Applied E Field) or 5 (Current Discontinuity) instead."
msgstr ""
"Jendela plot frekuensi ditutup: tipe eksitasi %d tidak kompatibel.\n"
"Gunakan tipe 0 (Applied E Field) atau 5 (Current Discontinuity) sebagai "
"gantinya."

#: src/callback_func.c:526
#, c-format
msgid ""
"Frequency plots are not available with excitation type %d.\n"
"This model uses Incident Field or Elementary Current Source excitation.\n"
"Change the EX card to type 0 (Applied E Field) or 5 (Current Discontinuity)."
msgstr ""
"Plot frekuensi tidak tersedia dengan tipe eksitasi %d.\n"
"Model ini menggunakan eksitasi Incident Field atau Elementary Current "
"Source.\n"
"Ubah kartu EX ke tipe 0 (Applied E Field) atau 5 (Current Discontinuity)."

