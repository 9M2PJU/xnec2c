msgstr ""
"tag=%d/seg=%d: съотношение дължина/радиус от %.1f < 2.0; грешката на полето "
"на стандартното ядро за тънък проводник надвишава 1%% със значителна разлика "
"(мин=2.0, 1%% точност=8.0)\n"

#: src/geometry.c:1870
#, c-format
msgid "tag=%d: suppressing additional standard kernel ratio errors\n"
msgstr ""
"tag=%d: потискане на допълнителни грешки за съотношение на стандартното "
"ядро\n"

#: src/geometry.c:1883
#, c-format
msgid ""
"tag=%d/seg=%d: length/radius ratio of %.1f < 8.0; standard thin-wire kernel "
"field error exceeds 1%% (min=2.0, 1%%accurate=8.0)\n"
msgstr ""
"tag=%d/seg=%d: съотношение дължина/радиус от %.1f < 8.0; грешката на полето "
"на стандартното ядро за тънък проводник надвишава 1%% (мин=2.0, 1%% "
"точност=8.0)\n"

#: src/geometry.c:1888
#, c-format
msgid "tag=%d: suppressing additional standard kernel ratio warnings\n"
msgstr ""
"tag=%d: потискане на допълнителни предупреждения за съотношение на "
"стандартното ядро\n"

#: src/geometry.c:1903
#, c-format
msgid ""
"tag=%d/seg=%d: length/radius ratio of %.1f < 0.5; extended thin-wire kernel "
"field error exceeds 1%% by a large margin (min=0.5, 1%%accurate=2.0)\n"
msgstr ""
"tag=%d/seg=%d: съотношение дължина/радиус от %.1f < 0.5; грешката на полето "
"на разширеното ядро за тънък проводник надвишава 1%% със значителна разлика "
"(мин=0.5, 1%% точност=2.0)\n"

#: src/geometry.c:1908
#, c-format
msgid "tag=%d: suppressing additional extended kernel ratio errors\n"
msgstr ""
"tag=%d: потискане на допълнителни грешки за съотношение на разширеното ядро\n"

#: src/geometry.c:1921
#, c-format
msgid ""
"tag=%d/seg=%d: length/radius ratio of %.1f < 2.0; extended thin-wire kernel "
"field error exceeds 1%% (min=0.5, 1%%accurate=2.0)\n"
msgstr ""
"tag=%d/seg=%d: съотношение дължина/радиус от %.1f < 2.0; грешката на полето "
"на разширеното ядро за тънък проводник надвишава 1%% (мин=0.5, 1%% "
"точност=2.0)\n"

#: src/geometry.c:1926
#, c-format
msgid "tag=%d: suppressing additional extended kernel ratio warnings\n"
msgstr ""
"tag=%d: потискане на допълнителни предупреждения за съотношение на "
"разширеното ядро\n"

