#: src/utils.c:45
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"Употреба: xnec2c [опции] [<име-на-входен-файл>]\n"
"  -i|--input         <име-на-входен-файл>\n"
"  -c|--config        <път-до-конфиг-файл>     - файлът трябва да съществува\n"
"  -C|--new-config    <път-до-нов-конфиг-файл> - създава файла, ако липсва\n"
"  -j|--jobs  <брой процесори в SMP машина> (-j0 деактивира разклоняването)\n"
"     --openblas-threads <n>  задава брой нишки за OpenBLAS (по подразбиране: "
"1)\n"
"     --mkl-threads <n>       задава брой нишки за Intel MKL (по "
"подразбиране: 1)\n"
"     --omp-threads <n>       задава брой нишки за OpenMP (по подразбиране: "
"1)\n"
"  -b|--batch:        активира пакетен режим, изход след изпълнение на "
"честотния цикъл\n"
"  -P|--no-pthreads:  деактивира pthreads и използва GTK цикъла за "
"отстраняване на грешки\n"
"  -h|--help:         извежда информация за употребата и излиза\n"
"  -V|--version:      извежда номера на версията на xnec2c и излиза\n"
"  -v|--verbose:      увеличава подробността, може да се зададе многократно\n"
"  -d|--debug:        активира изход за отстраняване на грешки (-dd включва "
"обратни проследявания)\n"
"  -d|--quiet:        потиска изхода за отстраняване на грешки/подробности\n"
"\n"
"  --optimize:        Активира оптимизатора незабавно.\n"
"  --skip-verify:     пропуска проверките за верификация на геометрията\n"
"\n"
"Следните аргументи записват в изходен файл след завършване на честотния\n"
"цикъл.  Те са полезни в комбинация с --batch; Ако искате да зададете\n"
"имена на файлове за запис без режим --batch, активирайте Файл->Настройки\n"
"за оптимизация, иначе файловете, зададени в командния ред, няма да бъдат "
"записани.\n"
"\n"
"  --write-csv             <име-на-файл>  - записва CSV файл с измервания\n"
"  --write-s1p             <име-на-файл>  - записва S1P файл с S-параметри\n"
"  --write-s2p-max-gain    <име-на-файл>  - записва S2P файл, порт-2 е макс-"
"усилване\n"
"  --write-s2p-viewer-gain <име-на-файл>  - записва S2P файл, порт-2 е "
"усилване-към-наблюдател\n"
"  --write-rdpat           <име-на-файл>  - записва CSV на диаграмата на "
"излъчване\n"
"  --write-currents        <име-на-файл>  - записва CSV на токове и заряди\n"
"  --write-gnuplot-structure <име-на-файл> - записва gnuplot файл на "
"структурата\n"
"  --write-patch-currents  <име-на-файл>  - записва CSV на повърхностни "
"токове на патчове\n"

