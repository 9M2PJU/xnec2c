msgstr ""
"tag=%d/seg=%d: разстояние до крайна точка=%.3e е твърде близко (под прага за "
"свързване=%.3e); сегментът ще се свърже със себе си\n"

#: src/geometry.c:1647
#, c-format
msgid "tag=%d: suppressing additional self-connection warnings\n"
msgstr "tag=%d: потискане на допълнителни предупреждения за самосвързване\n"

#: src/geometry.c:1692
#, c-format
msgid ""
"tag=%d/seg=%d: distance=%.3e to tag=%d/seg=%d closer than 2x connection "
"threshold %.3e; unintended connections possible\n"
msgstr ""
"tag=%d/seg=%d: разстояние=%.3e до tag=%d/seg=%d е по-близо от 2x праг за "
"свързване %.3e; възможни са непредвидени свързвания\n"

#: src/geometry.c:1697
#, c-format
msgid "tag=%d: suppressing additional overlap warnings\n"
msgstr "tag=%d: потискане на допълнителни предупреждения за припокриване\n"

#: src/geometry.c:1757
#, c-format
msgid ""
"tag=%d/seg=%d: length=%.3e is too short (and close enough) to tag=%d/seg=%d "
"length=%.3e that connection detection may fail or short\n"
msgstr ""
"tag=%d/seg=%d: дължина=%.3e е твърде къса (и достатъчно близка) до tag=%d/"
"seg=%d дължина=%.3e, че откриването на връзка може да се провали или да е "
"късо\n"

#: src/geometry.c:1762
#, c-format
msgid ""
"tag=%d: suppressing additional connection detection may fail or short "
"warnings\n"
msgstr ""
"tag=%d: потискане на допълнителни предупреждения за възможен провал на "
"откриване на връзка или късо съединение\n"

#: src/geometry.c:1794
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f < 0.001; similarity of "
"current components leads to numerical inaccuracies (min=0.001, fine=0.05, "
"recommended <= 0.1)\n"
msgstr ""
"tag=%d/seg=%d: съотношение дължина/дължина на вълната от %.3f < 0.001; "
"сходството на токовите компоненти води до числени неточности (мин=0.001, "
"добре=0.05, препоръчително <= 0.1)\n"

#: src/geometry.c:1799
#, c-format
msgid "tag=%d: suppressing additional short wavelength ratio errors\n"
msgstr ""
"tag=%d: потискане на допълнителни грешки за късо съотношение на дължина на "
"вълната\n"

#: src/geometry.c:1812
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.1; current sampling "
"resolution limited by segment spacing (min=0.001, fine=0.05, recommended <= "
"0.1)\n"
msgstr ""
"tag=%d/seg=%d: съотношение дължина/дължина на вълната от %.3f > 0.1; "
"разделителната способност на дискретизация на тока е ограничена от "
"разстоянието между сегментите (мин=0.001, добре=0.05, препоръчително <= "
"0.1)\n"

#: src/geometry.c:1817
#, c-format
msgid "tag=%d: suppressing additional long wavelength ratio warnings\n"
msgstr ""
"tag=%d: потискане на допълнителни предупреждения за дълго съотношение на "
"дължина на вълната\n"

#: src/geometry.c:1830
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.05; shorter segments "
"increase accuracy in regions of rapid current change (min=0.001, fine=0.05, "
"recommended <=0.1)\n"
msgstr ""
"tag=%d/seg=%d: съотношение дължина/дължина на вълната от %.3f > 0.05; по-"
"късите сегменти увеличават точността в области с бърза промяна на тока "
"(мин=0.001, добре=0.05, препоръчително <=0.1)\n"

#: src/geometry.c:1835
#, c-format
msgid "tag=%d: suppressing additional accuracy improvement suggestions\n"
msgstr ""
"tag=%d: потискане на допълнителни предложения за подобряване на точността\n"

#: src/geometry.c:1865
#, c-format
msgid ""
"tag=%d/seg=%d: length/radius ratio of %.1f < 2.0; standard thin-wire kernel "
