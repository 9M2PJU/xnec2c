msgid "Line Cap"
msgstr "Краища на линия"

#: resources/settings/cairo_settings.glade:125
msgid "Butt"
msgstr "Плосък"

#: resources/settings/cairo_settings.glade:132
msgid "Round"
msgstr "Заоблен"

#: resources/settings/cairo_settings.glade:139
msgid "Square"
msgstr "Квадратен"

#: resources/settings/cairo_settings.glade:151
msgid "Depth Bins"
msgstr "Дълбочинни нива"

#: resources/settings/cairo_settings.glade:184
#: resources/settings/opengl_settings.glade:533
#: resources/settings/render_settings.glade:50
msgid "Reset to _Defaults"
msgstr "Нулиране към _стандартни"

#: resources/settings/opengl_settings.glade:493
msgid "Visual only — does not affect NEC2 model calculations."
msgstr "Само визуално — не влияе на изчисленията на NEC2 модела."

#: resources/settings/render_settings.glade:72
msgid "Rendering Settings"
