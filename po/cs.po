"<= 0.1)\n"

#: src/geometry.c:1614
#, c-format
msgid "tag=%d: suppressing additional short wavelength ratio errors\n"
msgstr "tag=%d: potlačení dalších chyb krátkého poměru vlnové délky\n"

#: src/geometry.c:1628
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.1; current sampling "
