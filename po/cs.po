#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"Použití: xnec2c [volby] [<název-vstupního-souboru>]\n"
"  -i|--input         <název-vstupního-souboru>\n"
"  -c|--config        <cesta-konfiguračního-souboru>     - soubor musí "
"existovat\n"
"  -C|--new-config    <cesta-nového-konfiguračního-souboru> - vytvoří soubor, "
"pokud chybí\n"
"  -j|--jobs  <počet procesorů v SMP stroji> (-j0 zakáže forkování)\n"
"     --openblas-threads <n>  nastavit počet vláken OpenBLAS (výchozí: 1)\n"
"     --mkl-threads <n>       nastavit počet vláken Intel MKL (výchozí: 1)\n"
"     --omp-threads <n>       nastavit počet vláken OpenMP (výchozí: 1)\n"
"  -b|--batch:        povolit dávkový režim, ukončit po dokončení frekvenční "
"smyčky\n"
"  -P|--no-pthreads:  zakázat pthreads a použít GTK smyčku pro ladění\n"
"  -h|--help:         vypsat informace o použití a ukončit\n"
"  -V|--version:      vypsat číslo verze xnec2c a ukončit\n"
"  -v|--verbose:      zvýšit podrobnost, lze zadat vícekrát\n"
"  -d|--debug:        povolit ladicí výstup (-dd zahrnuje zásobníky volání)\n"
"  -d|--quiet:        potlačit ladicí/podrobný výstup\n"
"\n"
"  --optimize:        Okamžitě aktivovat optimalizátor.\n"
"  --skip-verify:     přeskočit kontroly ověření geometrie\n"
"  --mem-report:      hlásit živé bajty spravovaného alokátoru na místo "
"volání\n"
"\n"
"Následující argumenty zapisují do výstupního souboru po dokončení "
"frekvenční\n"
"smyčky. Jsou užitečné v kombinaci s --batch; Pokud chcete zadat názvy "
"souborů\n"
"k zápisu bez režimu --batch, povolte Soubor->Nastavení optimalizátoru, "
"jinak\n"
"soubory zadané na příkazovém řádku nebudou zapsány.\n"
"\n"
"  --write-csv             <název-souboru>  - zapsat CSV soubor měření\n"
"  --write-s1p             <název-souboru>  - zapsat S1P soubor S-parametrů\n"
"  --write-s2p-max-gain    <název-souboru>  - zapsat S2P soubor, port-2 je "
"max-gain\n"
"  --write-s2p-viewer-gain <název-souboru>  - zapsat S2P soubor, port-2 je "
"viewer-gain\n"
"  --write-rdpat           <název-souboru>  - zapsat CSV vyzařovacího "
"diagramu\n"
"  --write-currents        <název-souboru>  - zapsat CSV proudů a nábojů\n"
"  --write-gnuplot-structure <název-souboru> - zapsat soubor struktury "
"gnuplot\n"
"  --write-patch-currents  <název-souboru>  - zapsat CSV proudů plošek\n"
"  --write-validation-dir <adresář> - zapsat celý strom ověřovacích dat\n"

