msgstr "tag=%d: potlačení dalších varování dlouhého poměru vlnové délky\n"

#: src/geometry.c:1647
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.05; shorter segments "
