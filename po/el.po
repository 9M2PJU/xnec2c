#: src/utils.c:45
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"Χρήση: xnec2c [επιλογές] [<όνομα-αρχείου-εισόδου>]\n"
"  -i|--input         <όνομα-αρχείου-εισόδου>\n"
"  -c|--config        <διαδρομή-αρχείου-ρυθμίσεων>     - το αρχείο πρέπει να "
"υπάρχει\n"
"  -C|--new-config    <διαδρομή-νέου-αρχείου-ρυθμίσεων> - δημιουργεί το "
"αρχείο αν λείπει\n"
"  -j|--jobs  <αριθμός επεξεργαστών σε μηχανή SMP> (-j0 απενεργοποιεί το "
"forking)\n"
"     --openblas-threads <n>  ορισμός αριθμού νημάτων OpenBLAS (προεπιλογή: "
"1)\n"
"     --mkl-threads <n>       ορισμός αριθμού νημάτων Intel MKL (προεπιλογή: "
"1)\n"
"     --omp-threads <n>       ορισμός αριθμού νημάτων OpenMP (προεπιλογή: 1)\n"
"  -b|--batch:        ενεργοποίηση λειτουργίας δέσμης, έξοδος μετά την "
"εκτέλεση του βρόχου συχνότητας\n"
"  -P|--no-pthreads:  απενεργοποίηση pthreads και χρήση του βρόχου GTK για "
"αποσφαλμάτωση\n"
"  -h|--help:         εμφάνιση πληροφοριών χρήσης και έξοδος\n"
"  -V|--version:      εμφάνιση αριθμού έκδοσης xnec2c και έξοδος\n"
"  -v|--verbose:      αύξηση λεπτομέρειας, μπορεί να καθοριστεί πολλές φορές\n"
"  -d|--debug:        ενεργοποίηση εξόδου αποσφαλμάτωσης (-dd περιλαμβάνει "
"backtraces)\n"
"  -d|--quiet:        καταστολή εξόδου αποσφαλμάτωσης/λεπτομέρειας\n"
"\n"
"  --optimize:        Ενεργοποίηση του βελτιστοποιητή αμέσως.\n"
"  --skip-verify:     παράλειψη ελέγχων επαλήθευσης γεωμετρίας\n"
"\n"
"Τα ακόλουθα ορίσματα γράφουν σε αρχείο εξόδου μετά την ολοκλήρωση του "
"βρόχου\n"
"συχνότητας.  Αυτά είναι χρήσιμα σε συνδυασμό με --batch· Αν θέλετε να "
"καθορίσετε\n"
"ονόματα αρχείων για εγγραφή χωρίς λειτουργία --batch τότε ενεργοποιήστε τις "
"Ρυθμίσεις\n"
"Βελτιστοποιητή από το μενού Αρχείο διαφορετικά τα αρχεία που καθορίζετε στη "
"γραμμή\n"
"εντολών δεν θα εγγραφούν.\n"
"\n"
"  --write-csv             <όνομα αρχείου>  - εγγραφή αρχείου CSV μετρήσεων\n"
"  --write-s1p             <όνομα αρχείου>  - εγγραφή αρχείου S1P παραμέτρων "
"S\n"
"  --write-s2p-max-gain    <όνομα αρχείου>  - εγγραφή αρχείου S2P, η θύρα-2 "
"είναι μέγιστο κέρδος\n"
"  --write-s2p-viewer-gain <όνομα αρχείου>  - εγγραφή αρχείου S2P, η θύρα-2 "
"είναι κέρδος παρατηρητή\n"
"  --write-rdpat           <όνομα αρχείου>  - εγγραφή CSV διαγράμματος "
"ακτινοβολίας\n"
"  --write-currents        <όνομα αρχείου>  - εγγραφή CSV ρευμάτων και "
"φορτίων\n"
"  --write-gnuplot-structure <όνομα αρχείου> - εγγραφή αρχείου δομής gnuplot\n"
"  --write-patch-currents  <όνομα αρχείου>  - εγγραφή CSV ρευμάτων "
"επιφανειακών patch\n"

