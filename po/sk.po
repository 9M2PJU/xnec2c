#: src/utils.c:45
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"Použitie: xnec2c [voľby] [<názov-vstupného-súboru>]\n"
"  -i|--input         <názov-vstupného-súboru>\n"
"  -c|--config        <cesta-konfiguračného-súboru>     - súbor musí "
"existovať\n"
"  -C|--new-config    <cesta-nového-konfiguračného-súboru> - vytvorí súbor ak "
"chýba\n"
"  -j|--jobs  <počet procesorov v SMP stroji> (-j0 zakáže forkovanie)\n"
"     --openblas-threads <n>  nastaviť počet vlákien OpenBLAS (predvolené: "
"1)\n"
"     --mkl-threads <n>       nastaviť počet vlákien Intel MKL (predvolené: "
"1)\n"
"     --omp-threads <n>       nastaviť počet vlákien OpenMP (predvolené: 1)\n"
"  -b|--batch:        povoliť dávkový režim, ukončiť po dokončení frekvenčnej "
"slučky\n"
"  -P|--no-pthreads:  zakázať pthreads a použiť GTK slučku pre ladenie\n"
"  -h|--help:         vypísať informácie o použití a ukončiť\n"
"  -V|--version:      vypísať číslo verzie xnec2c a ukončiť\n"
"  -v|--verbose:      zvýšiť podrobnosť, možno zadať viackrát\n"
"  -d|--debug:        povoliť ladiaci výstup (-dd vrátane spätných "
"sledovaní)\n"
"  -d|--quiet:        potlačiť ladiaci/podrobný výstup\n"
"\n"
"  --optimize:        Okamžite aktivovať optimalizátor.\n"
"  --skip-verify:     preskočiť kontroly overenia geometrie\n"
"\n"
"Nasledujúce argumenty zapisujú do výstupného súboru po dokončení "
"frekvenčnej\n"
"slučky. Tieto sú užitočné v kombinácii s --batch; Ak chcete zadať názvy "
"súborov\n"
"na zápis bez režimu --batch, povoľte Súbor->Nastavenia optimalizátora, inak\n"
"súbory zadané na príkazovom riadku nebudú zapísané.\n"
"\n"
"  --write-csv             <súbor>  - zapísať CSV súbor meraní\n"
"  --write-s1p             <súbor>  - zapísať S1P súbor S-parametrov\n"
"  --write-s2p-max-gain    <súbor>  - zapísať S2P súbor, port-2 je max-zisk\n"
"  --write-s2p-viewer-gain <súbor>  - zapísať S2P súbor, port-2 je zisk-"
"zobrazovača\n"
"  --write-rdpat           <súbor>  - zapísať CSV vyžarovacieho diagramu\n"
"  --write-currents        <súbor>  - zapísať CSV prúdov a nábojov\n"
"  --write-gnuplot-structure <súbor> - zapísať súbor gnuplot štruktúry\n"
"  --write-patch-currents  <súbor>  - zapísať CSV prúdov povrchových patchov\n"

