msgstr "tag=%d: се потиснуваат дополнителни предупредувања за преклопување\n"

#: src/geometry.c:1757
#, c-format
msgid ""
"tag=%d/seg=%d: length=%.3e is too short (and close enough) to tag=%d/seg=%d "
