#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"Употреба: xnec2c [опции] [<име-на-влезна-датотека>]\n"
"  -i|--input         <име-на-влезна-датотека>\n"
"  -c|--config        <патека-до-конфиг-датотека>     - датотеката мора да "
"постои\n"
"  -C|--new-config    <патека-до-нова-конфиг-датотека> - ја создава "
"датотеката ако недостасува\n"
"  -j|--jobs  <број на процесори во SMP машина> (-j0 го оневозможува "
"разгранувањето)\n"
"     --openblas-threads <n>  постави број на OpenBLAS нишки (стандардно: 1)\n"
"     --mkl-threads <n>       постави број на Intel MKL нишки (стандардно: "
"1)\n"
"     --omp-threads <n>       постави број на OpenMP нишки (стандардно: 1)\n"
"  -b|--batch:        овозможи сериски режим, излези по извршување на "
"фреквентната јамка\n"
"  -P|--no-pthreads:  оневозможи pthreads и користи GTK јамка за дебагирање\n"
"  -h|--help:         прикажи информации за употреба и излези\n"
"  -V|--version:      прикажи број на верзија на xnec2c и излези\n"
"  -v|--verbose:      зголеми детализирање, може да се наведе повеќе пати\n"
"  -d|--debug:        овозможи debug излез (-dd вклучува backtraces)\n"
"  -d|--quiet:        потисни debug/verbose излез\n"
"\n"
"  --optimize:        Активирај го оптимизаторот веднаш.\n"
"  --skip-verify:     прескокни проверки за верификација на геометрија\n"
"  --mem-report:      извештај за активни бајти на управуван алокатор по "
"место на повик\n"
"\n"
"Следните аргументи запишуваат во излезна датотека по завршување на\n"
"фреквентната јамка. Овие се корисни во комбинација со --batch; Ако сакате "
"да\n"
"наведете имиња на датотеки за запишување без --batch режим тогаш овозможете\n"
"File->Optimizer Settings или датотеките што ги наведовте на командната "
"линија\n"
"нема да бидат запишани.\n"
"\n"
"  --write-csv             <датотека>  - запиши CSV датотека со мерења\n"
"  --write-s1p             <датотека>  - запиши S1P датотека со S-параметри\n"
"  --write-s2p-max-gain    <датотека>  - запиши S2P датотека, port-2 е max-"
"gain\n"
"  --write-s2p-viewer-gain <датотека>  - запиши S2P датотека, port-2 е viewer-"
"gain\n"
"  --write-rdpat           <датотека>  - запиши CSV на дијаграмот на зрачење\n"
"  --write-currents        <датотека>  - запиши CSV на струи и полнежи\n"
"  --write-gnuplot-structure <датотека> - запиши gnuplot датотека на "
"структура\n"
"  --write-patch-currents  <датотека>  - запиши CSV на струи на површински "
"плочки\n"

