#: src/geometry.c:1883
#, c-format
msgid ""
"tag=%d/seg=%d: length/radius ratio of %.1f < 8.0; standard thin-wire kernel "
"field error exceeds 1%% (min=2.0, 1%%accurate=8.0)\n"
msgstr ""
"tag=%d/seg=%d: однос дужина/радијус од %.1f < 8.0; грешка поља стандардног "
