#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"Употреба: xnec2c [опције] [<име-улазне-датотеке>]\n"
"  -i|--input         <име-улазне-датотеке>\n"
"  -c|--config        <путања-конфиг-датотеке>     - датотека мора да "
"постоји\n"
"  -C|--new-config    <путања-нове-конфиг-датотеке> - креира датотеку ако "
"недостаје\n"
"  -j|--jobs  <број процесора у SMP машини> (-j0 онемогућава форковање)\n"
"     --openblas-threads <n>  подеси број OpenBLAS нити (подразумевано: 1)\n"
"     --mkl-threads <n>       подеси број Intel MKL нити (подразумевано: 1)\n"
"     --omp-threads <n>       подеси број OpenMP нити (подразумевано: 1)\n"
"  -b|--batch:        омогући batch режим, изађи након извршавања "
"фреквенцијске петље\n"
"  -P|--no-pthreads:  онемогући pthreads и користи GTK петљу за отклањање "
"грешака\n"
"  -h|--help:         прикажи информације о употреби и изађи\n"
"  -V|--version:      прикажи број верзије xnec2c и изађи\n"
"  -v|--verbose:      повећај опширност, може се навести више пута\n"
"  -d|--debug:        омогући debug излаз (-dd укључује backtraces)\n"
"  -d|--quiet:        потисни debug/verbose излаз\n"
"\n"
"  --optimize:        Одмах активирај оптимизатор.\n"
"  --skip-verify:     прескочи провере верификације геометрије\n"
"  --mem-report:      извештај о живим бајтовима управљаног алокатора по "
"локацији позива\n"
"\n"
"Следећи аргументи уписују у излазну датотеку након завршетка фреквенцијске "
"петље.\n"
"Ово је корисно комбиновати са --batch; Ако желите да наведете имена "
"датотека\n"
"за упис без --batch режима, омогућите Датотека->Подешавања оптимизације или "
"датотеке\n"
"које наведете у командној линији неће бити уписане.\n"
"\n"
"  --write-csv             <име-датотеке>  - упиши CSV датотеку мерења\n"
"  --write-s1p             <име-датотеке>  - упиши S1P датотеку S-параметара\n"
"  --write-s2p-max-gain    <име-датотеке>  - упиши S2P датотеку, port-2 је "
"max-gain\n"
"  --write-s2p-viewer-gain <име-датотеке>  - упиши S2P датотеку, port-2 је "
"viewer-gain\n"
"  --write-rdpat           <име-датотеке>  - упиши CSV дијаграма зрачења\n"
"  --write-currents        <име-датотеке>  - упиши CSV струја и "
"наелектрисања\n"
"  --write-gnuplot-structure <име-датотеке> - упиши gnuplot датотеку "
"структуре\n"
"  --write-patch-currents  <име-датотеке>  - упиши CSV патч површинских "
"струја\n"
"  --write-validation-dir <директоријум> - упиши потпуно дрво података "
"верификације\n"

