msgstr ""
"tag=%d/seg=%d: однос дужина/таласна дужина од %.3f > 0.1; резолуција "
"узорковања струје ограничена размаком сегмената (мин=0.001, добро=0.05, "
"препоручено <= 0.1)\n"

#: src/geometry.c:1685
#, c-format
msgid "tag=%d: suppressing additional long wavelength ratio warnings\n"
msgstr "tag=%d: потискивање додатних упозорења дугог односа таласне дужине\n"

#: src/geometry.c:1699
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.05; shorter segments "
"increase accuracy in regions of rapid current change (min=0.001, fine=0.05, "
"recommended <=0.1)\n"
msgstr ""
"tag=%d/seg=%d: однос дужина/таласна дужина од %.3f > 0.05; краћи сегменти "
"повећавају тачност у областима брзе промене струје (мин=0.001, добро=0.05, "
"препоручено <=0.1)\n"

#: src/geometry.c:1704
#, c-format
msgid "tag=%d: suppressing additional accuracy improvement suggestions\n"
msgstr "tag=%d: потискивање додатних предлога за побољшање тачности\n"

