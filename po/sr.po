#: src/geometry.c:1888
#, c-format
msgid "tag=%d: suppressing additional standard kernel ratio warnings\n"
msgstr "tag=%d: потискивање додатних упозорења односа стандардног језгра\n"

#: src/geometry.c:1903
#, c-format
msgid ""
