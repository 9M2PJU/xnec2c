msgstr "tag=%d: потискивање додатних упозорења дугог односа таласне дужине\n"

#: src/geometry.c:1830
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.05; shorter segments "
