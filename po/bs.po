#: src/callback_func.c:520
#, c-format
msgid ""
"Frequency plots window closed: excitation type %d is incompatible.\n"
"Use type 0 (Applied E Field) or 5 (Current Discontinuity) instead."
msgstr ""
"Prozor frekventnih grafova zatvoren: tip pobude %d nije kompatibilan.\n"
"Koristite tip 0 (Primijenjeno E polje) ili 5 (Diskontinuitet struje) umjesto "
"toga."

#: src/callback_func.c:526
#, c-format
msgid ""
"Frequency plots are not available with excitation type %d.\n"
"This model uses Incident Field or Elementary Current Source excitation.\n"
"Change the EX card to type 0 (Applied E Field) or 5 (Current Discontinuity)."
msgstr ""
"Frekventni grafovi nisu dostupni s tipom pobude %d.\n"
"Ovaj model koristi pobudu upadnim poljem ili elementarnim izvorom struje.\n"
"Promijenite EX karticu na tip 0 (Primijenjeno E polje) ili 5 (Diskontinuitet "
"struje)."

