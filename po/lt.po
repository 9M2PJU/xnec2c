#: src/utils.c:45
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"Naudojimas: xnec2c [parinktys] [<įvesties-failo-pavadinimas>]\n"
"  -i|--input         <įvesties-failo-pavadinimas>\n"
"  -c|--config        <konfigūracijos-failo-kelias>     - failas turi "
"egzistuoti\n"
"  -C|--new-config    <naujo-konfigūracijos-failo-kelias> - sukuria failą, "
"jei trūksta\n"
"  -j|--jobs  <procesorių skaičius SMP įrenginyje> (-j0 išjungia procesų "
"kūrimą)\n"
"     --openblas-threads <n>  nustatyti OpenBLAS gijų skaičių (numatyta: 1)\n"
"     --mkl-threads <n>       nustatyti Intel MKL gijų skaičių (numatyta: 1)\n"
"     --omp-threads <n>       nustatyti OpenMP gijų skaičių (numatyta: 1)\n"
"  -b|--batch:        įjungti paketinį režimą, išeiti po dažnio ciklo\n"
"  -P|--no-pthreads:  išjungti pthreads ir naudoti GTK ciklą derinimui\n"
"  -h|--help:         išspausdinti naudojimo informaciją ir išeiti\n"
"  -V|--version:      išspausdinti xnec2c versijos numerį ir išeiti\n"
"  -v|--verbose:      padidinti išsamumą, gali būti nurodyta kelis kartus\n"
"  -d|--debug:        įjungti derinimo išvestį (-dd įtraukia steko sekimus)\n"
"  -d|--quiet:        slopinti derinimo/išsamią išvestį\n"
"\n"
"  --optimize:        Aktyvuoti optimizatorių nedelsiant.\n"
"  --skip-verify:     praleisti geometrijos tikrinimo patikras\n"
"\n"
"Toliau nurodyti argumentai įrašo į išvesties failą pasibaigus dažnio "
"ciklui.\n"
"Jie naudingi derinti su --batch; Jei norite nurodyti failo pavadinimus\n"
"įrašymui be --batch režimo, įjunkite Failas->Optimizavimo nustatymai\n"
"arba nurodyti komandinėje eilutėje failai nebus įrašyti.\n"
"\n"
"  --write-csv             <failo-pavadinimas>  - įrašyti CSV failą su "
"matavimais\n"
"  --write-s1p             <failo-pavadinimas>  - įrašyti S1P failą su S-"
"parametrais\n"
"  --write-s2p-max-gain    <failo-pavadinimas>  - įrašyti S2P failą, "
"prievadas-2 yra maks-stiprinimas\n"
"  --write-s2p-viewer-gain <failo-pavadinimas>  - įrašyti S2P failą, "
"prievadas-2 yra peržiūros-stiprinimas\n"
"  --write-rdpat           <failo-pavadinimas>  - įrašyti CSV su "
"spinduliuotės diagrama\n"
"  --write-currents        <failo-pavadinimas>  - įrašyti CSV su srovėmis ir "
"krūviais\n"
"  --write-gnuplot-structure <failo-pavadinimas> - įrašyti gnuplot struktūros "
"failą\n"
"  --write-patch-currents  <failo-pavadinimas>  - įrašyti CSV su lopinėlių "
"paviršiaus srovėmis\n"

