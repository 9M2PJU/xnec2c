#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"ব্যবহার: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - ফাইলটি অবশ্যই বিদ্যমান থাকতে "
"হবে\n"
"  -C|--new-config    <new-config-file-path> - অনুপস্থিত থাকলে ফাইল তৈরি করে\n"
"  -j|--jobs  <SMP মেশিনে প্রসেসরের সংখ্যা> (-j0 forking নিষ্ক্রিয় করে)\n"
"     --openblas-threads <n>  OpenBLAS থ্রেড সংখ্যা সেট করুন (ডিফল্ট: 1)\n"
"     --mkl-threads <n>       Intel MKL থ্রেড সংখ্যা সেট করুন (ডিফল্ট: 1)\n"
"     --omp-threads <n>       OpenMP থ্রেড সংখ্যা সেট করুন (ডিফল্ট: 1)\n"
"  -b|--batch:        ব্যাচ মোড সক্রিয় করুন, ফ্রিকোয়েন্সি লুপ চালানোর পর প্রস্থান "
"করুন\n"
"  -P|--no-pthreads:  pthreads নিষ্ক্রিয় করুন এবং ডিবাগিংয়ের জন্য GTK লুপ ব্যবহার "
"করুন\n"
"  -h|--help:         ব্যবহারের তথ্য প্রিন্ট করুন এবং প্রস্থান করুন\n"
"  -V|--version:      xnec2c সংস্করণ নম্বর প্রিন্ট করুন এবং প্রস্থান করুন\n"
"  -v|--verbose:      বিস্তারিত বাড়ান, একাধিকবার নির্দিষ্ট করা যায়\n"
"  -d|--debug:        ডিবাগ আউটপুট সক্রিয় করুন (-dd backtraces অন্তর্ভুক্ত করে)\n"
"  -d|--quiet:        ডিবাগ/বিস্তারিত আউটপুট দমন করুন\n"
"\n"
"  --optimize:        অবিলম্বে অপ্টিমাইজার সক্রিয় করুন।\n"
"  --skip-verify:     জ্যামিতি যাচাইকরণ পরীক্ষা এড়িয়ে যান\n"
"  --mem-report:      প্রতি কল সাইটে ম্যানেজড অ্যালোকেটর লাইভ বাইট রিপোর্ট করুন\n"
"\n"
"নিম্নলিখিত আর্গুমেন্টগুলি ফ্রিকোয়েন্সি লুপ সম্পন্ন হওয়ার পরে একটি আউটপুট ফাইলে লেখে।\n"
"এগুলি --batch এর সাথে একত্রিত করতে কার্যকর; আপনি যদি --batch মোড ছাড়া\n"
"লেখার জন্য ফাইলনাম নির্দিষ্ট করতে চান তাহলে File->Optimizer Settings সক্রিয় করুন\n"
"অথবা কমান্ড লাইনে আপনি যে ফাইলগুলি নির্দিষ্ট করেছেন সেগুলি লেখা হবে না।\n"
"\n"
"  --write-csv             <filename>  - পরিমাপের CSV ফাইল লিখুন\n"
"  --write-s1p             <filename>  - S-parameters এর S1P ফাইল লিখুন\n"
"  --write-s2p-max-gain    <filename>  - S2P ফাইল লিখুন, port-2 হল max-gain\n"
"  --write-s2p-viewer-gain <filename>  - S2P ফাইল লিখুন, port-2 হল viewer-"
"gain\n"
"  --write-rdpat           <filename>  - রেডিয়েশন প্যাটার্নের CSV লিখুন\n"
"  --write-currents        <filename>  - কারেন্ট এবং চার্জের CSV লিখুন\n"
"  --write-gnuplot-structure <filename> - gnuplot স্ট্রাকচার ফাইল লিখুন\n"
"  --write-patch-currents  <filename>  - প্যাচ সারফেস কারেন্টের CSV লিখুন\n"
"  --write-validation-dir <directory> - সম্পূর্ণ ভ্যালিডেশন ডেটা ট্রি লিখুন\n"

