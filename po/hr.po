"preporučeno <= 0.1)\n"

#: src/geometry.c:1652
#, c-format
msgid "tag=%d: suppressing additional long wavelength ratio warnings\n"
msgstr "tag=%d: potiskivanje dodatnih upozorenja dugog omjera valne duljine\n"

