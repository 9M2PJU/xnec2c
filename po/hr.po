#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"Uporaba: xnec2c [opcije] [<ime-ulazne-datoteke>]\n"
"  -i|--input         <ime-ulazne-datoteke>\n"
"  -c|--config        <putanja-konfiguracijske-datoteke>     - datoteka mora "
"postojati\n"
"  -C|--new-config    <putanja-nove-konfiguracijske-datoteke> - stvara "
"datoteku ako nedostaje\n"
"  -j|--jobs  <broj procesora u SMP stroju> (-j0 onemogućuje račvanje)\n"
"     --openblas-threads <n>  postavi broj OpenBLAS dretvi (zadano: 1)\n"
"     --mkl-threads <n>       postavi broj Intel MKL dretvi (zadano: 1)\n"
"     --omp-threads <n>       postavi broj OpenMP dretvi (zadano: 1)\n"
"  -b|--batch:        omogući skupni način, izlaz nakon završetka "
"frekvencijske petlje\n"
"  -P|--no-pthreads:  onemogući pthreads i koristi GTK petlju za debugiranje\n"
"  -h|--help:         ispiši informacije o uporabi i izađi\n"
"  -V|--version:      ispiši broj verzije xnec2c i izađi\n"
"  -v|--verbose:      povećaj opširnost, može se navesti više puta\n"
"  -d|--debug:        omogući debug izlaz (-dd uključuje povratne tragove)\n"
"  -d|--quiet:        suzbij debug/verbose izlaz\n"
"\n"
"  --optimize:        Odmah aktiviraj optimizator.\n"
"  --skip-verify:     preskoči provjere verifikacije geometrije\n"
"  --mem-report:      izvijesti o živim bajtovima upravljanog alokatora po "
"lokaciji poziva\n"
"\n"
"Sljedeći argumenti zapisuju u izlaznu datoteku nakon završetka "
"frekvencijske\n"
"petlje. Korisni su u kombinaciji s --batch; Ako želite navesti imena "
"datoteka\n"
"za zapisivanje bez --batch načina, omogućite Datoteka->Postavke "
"optimizatora\n"
"ili se datoteke koje navedete u naredbenom retku neće zapisati.\n"
"\n"
"  --write-csv             <ime-datoteke>  - zapiši CSV datoteku mjerenja\n"
"  --write-s1p             <ime-datoteke>  - zapiši S1P datoteku S-"
"parametara\n"
"  --write-s2p-max-gain    <ime-datoteke>  - zapiši S2P datoteku, port-2 je "
"max-gain\n"
"  --write-s2p-viewer-gain <ime-datoteke>  - zapiši S2P datoteku, port-2 je "
"viewer-gain\n"
"  --write-rdpat           <ime-datoteke>  - zapiši CSV dijagrama zračenja\n"
"  --write-currents        <ime-datoteke>  - zapiši CSV struja i naboja\n"
"  --write-gnuplot-structure <ime-datoteke> - zapiši gnuplot datoteku "
"strukture\n"
"  --write-patch-currents  <ime-datoteke>  - zapiši CSV struja zakrpa "
"površine\n"
"  --write-validation-dir <direktorij> - zapiši potpuno stablo validacijskih "
"podataka\n"

