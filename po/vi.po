#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"Cách dùng: xnec2c [tùy chọn] [<tên-tệp-đầu-vào>]\n"
"  -i|--input         <tên-tệp-đầu-vào>\n"
"  -c|--config        <đường-dẫn-tệp-cấu-hình>     - tệp phải tồn tại\n"
"  -C|--new-config    <đường-dẫn-tệp-cấu-hình-mới> - tạo tệp khi chưa có\n"
"  -j|--jobs  <số bộ xử lý trong máy SMP> (-j0 vô hiệu hóa forking)\n"
"     --openblas-threads <n>  đặt số luồng OpenBLAS (mặc định: 1)\n"
"     --mkl-threads <n>       đặt số luồng Intel MKL (mặc định: 1)\n"
"     --omp-threads <n>       đặt số luồng OpenMP (mặc định: 1)\n"
"  -b|--batch:        bật chế độ batch, thoát sau khi vòng lặp tần số chạy "
"xong\n"
"  -P|--no-pthreads:  vô hiệu hóa pthreads và dùng vòng lặp GTK để gỡ lỗi\n"
"  -h|--help:         in thông tin cách dùng và thoát\n"
"  -V|--version:      in số phiên bản xnec2c và thoát\n"
"  -v|--verbose:      tăng mức chi tiết, có thể chỉ định nhiều lần\n"
"  -d|--debug:        bật đầu ra gỡ lỗi (-dd bao gồm backtraces)\n"
"  -d|--quiet:        ẩn đầu ra gỡ lỗi/chi tiết\n"
"\n"
"  --optimize:        Kích hoạt bộ tối ưu hóa ngay lập tức.\n"
"  --skip-verify:     bỏ qua kiểm tra xác minh hình học\n"
"  --mem-report:      báo cáo byte còn hoạt động của bộ cấp phát được quản lý "
"theo mỗi vị trí gọi\n"
"\n"
"Các đối số sau ghi vào tệp đầu ra sau khi vòng lặp tần số hoàn thành. Chúng "
"hữu ích khi kết hợp với --batch; Nếu bạn muốn chỉ định tên tệp để ghi mà "
"không có chế độ --batch thì hãy bật Tệp->Cài đặt Bộ tối ưu hóa hoặc các tệp "
"bạn chỉ định trên dòng lệnh sẽ không được ghi.\n"
"\n"
"  --write-csv             <tên-tệp>  - ghi tệp CSV của các phép đo\n"
"  --write-s1p             <tên-tệp>  - ghi tệp S1P của S-parameters\n"
"  --write-s2p-max-gain    <tên-tệp>  - ghi tệp S2P, cổng-2 là max-gain\n"
"  --write-s2p-viewer-gain <tên-tệp>  - ghi tệp S2P, cổng-2 là viewer-gain\n"
"  --write-rdpat           <tên-tệp>  - ghi CSV của giản đồ bức xạ\n"
"  --write-currents        <tên-tệp>  - ghi CSV của dòng điện và điện tích\n"
"  --write-gnuplot-structure <tên-tệp> - ghi tệp cấu trúc gnuplot\n"
"  --write-patch-currents  <tên-tệp>  - ghi CSV của dòng điện bề mặt mảnh\n"
"  --write-validation-dir <thư-mục> - ghi toàn bộ cây dữ liệu kiểm định\n"

