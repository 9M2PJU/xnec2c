msgid ""
"A new NEC2 input file may not be created\n"
"while the Frequency Loop is running"
msgstr ""
"Không thể tạo tệp đầu vào NEC2 mới\n"
"khi vòng lặp tần số đang chạy"

#: src/callbacks.c:222
