#: src/callbacks.c:56 src/callbacks.c:72
msgid "Antenna Temperature"
msgstr "Nhiệt độ ăng-ten"

#: src/callbacks.c:57
msgid ""
"Ground plane detected in model. T_ant results will overcount ground effects. "
"Free-space models are standard for antenna temperature evaluation."
msgstr ""
"Phát hiện mặt phẳng đất trong mô hình. Kết quả T_ant sẽ tính thừa hiệu ứng "
"đất. Mô hình không gian tự do là tiêu chuẩn để đánh giá nhiệt độ ăng-ten."

#: src/callbacks.c:73
#, c-format
msgid ""
"Max gain at θ=%.0f° (%.0f° from XY plane). Convention assumes beam in XY "
"plane with observation elevation set by spinbutton."
msgstr ""
"Độ lợi cực đại tại θ=%.0f° (%.0f° từ mặt phẳng XY). Quy ước giả định chùm "
"tia nằm trong mặt phẳng XY với góc ngẩng quan sát được đặt bởi spinbutton."

