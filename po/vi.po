#: src/callback_func.c:263
msgid ""
"The frequency loop is running\n"
"Are you sure you wish to end the calculation?"
msgstr ""
"Vòng lặp tần số đang chạy\n"
"Bạn có chắc chắn muốn kết thúc tính toán không?"

#: src/callback_func.c:267
msgid ""
"The frequency loop is running\n"
"Are you sure you wish to close this window?"
msgstr ""
"Vòng lặp tần số đang chạy\n"
"Bạn có chắc chắn muốn đóng cửa sổ này không?"

#: src/callback_func.c:520
#, c-format
msgid ""
"Frequency plots window closed: excitation type %d is incompatible.\n"
"Use type 0 (Applied E Field) or 5 (Current Discontinuity) instead."
msgstr ""
"Cửa sổ biểu đồ tần số đã đóng: loại kích thích %d không tương thích.\n"
"Sử dụng loại 0 (Applied E Field) hoặc 5 (Current Discontinuity) thay thế."

#: src/callback_func.c:526
#, c-format
msgid ""
"Frequency plots are not available with excitation type %d.\n"
"This model uses Incident Field or Elementary Current Source excitation.\n"
"Change the EX card to type 0 (Applied E Field) or 5 (Current Discontinuity)."
msgstr ""
"Biểu đồ tần số không khả dụng với loại kích thích %d.\n"
"Mô hình này sử dụng kích thích Incident Field hoặc Elementary Current "
"Source.\n"
"Thay đổi thẻ EX sang loại 0 (Applied E Field) hoặc 5 (Current Discontinuity)."

