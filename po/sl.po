#: src/utils.c:42
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"  --mem-report:      report managed allocator live bytes per call site\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
"  --write-validation-dir <directory> - write full validation data tree\n"
msgstr ""
"Uporaba: xnec2c [možnosti] [<ime-vhodne-datoteke>]\n"
"  -i|--input         <ime-vhodne-datoteke>\n"
"  -c|--config        <pot-konfiguracijske-datoteke>     - datoteka mora "
"obstajati\n"
"  -C|--new-config    <pot-nove-konfiguracijske-datoteke> - ustvari datoteko, "
"če manjka\n"
"  -j|--jobs  <število procesorjev v napravi SMP> (-j0 onemogoči razvejanje)\n"
"     --openblas-threads <n>  nastavi število niti OpenBLAS (privzeto: 1)\n"
"     --mkl-threads <n>       nastavi število niti Intel MKL (privzeto: 1)\n"
"     --omp-threads <n>       nastavi število niti OpenMP (privzeto: 1)\n"
"  -b|--batch:        omogoči paketni način, izhod po izvedbi frekvenčne "
"zanke\n"
"  -P|--no-pthreads:  onemogoči pthreads in uporabi zanko GTK za "
"razhroščevanje\n"
"  -h|--help:         izpiši informacije o uporabi in izhod\n"
"  -V|--version:      izpiši različico xnec2c in izhod\n"
"  -v|--verbose:      povečaj podrobnost izpisa, lahko se navede večkrat\n"
"  -d|--debug:        omogoči razhroščevalni izpis (-dd vključi sledi "
"klicev)\n"
"  -d|--quiet:        onemogoči razhroščevalni/podrobni izpis\n"
"\n"
"  --optimize:        Takoj aktiviraj optimizator.\n"
"  --skip-verify:     preskoči preverjanje geometrije\n"
"  --mem-report:      poročaj o živih bajtih upravljanega dodeljevalnika po "
"mestu klica\n"
"\n"
"Naslednji argumenti zapišejo izhodno datoteko po zaključku frekvenčne\n"
"zanke. Uporabni so v kombinaciji z --batch; če želite navesti imena\n"
"datotek za zapis brez načina --batch, omogočite Datoteka->Nastavitve\n"
"optimizacije, sicer datoteke, navedene v ukazni vrstici, ne bodo zapisane.\n"
"\n"
"  --write-csv             <ime datoteke>  - zapiši datoteko CSV z meritvami\n"
"  --write-s1p             <ime datoteke>  - zapiši datoteko S1P s parametri "
"S\n"
"  --write-s2p-max-gain    <ime datoteke>  - zapiši datoteko S2P, vrata 2 so "
"maks. ojačitev\n"
"  --write-s2p-viewer-gain <ime datoteke>  - zapiši datoteko S2P, vrata 2 so "
"ojačitev pregledovalnika\n"
"  --write-rdpat           <ime datoteke>  - zapiši CSV sevalnega diagrama\n"
"  --write-currents        <ime datoteke>  - zapiši CSV tokov in nabojev\n"
"  --write-gnuplot-structure <ime datoteke> - zapiši datoteko strukture "
"gnuplot\n"
"  --write-patch-currents  <ime datoteke>  - zapiši CSV površinskih tokov "
"patchev\n"
"  --write-validation-dir <imenik> - zapiši celotno drevo validacijskih "
"podatkov\n"

