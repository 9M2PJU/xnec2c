msgstr ""
"tag=%d/seg=%d: 端点距離=%.3eが近すぎます（接続閾値=%.3e未満）; セグメントが自"
"己接続します\n"

#: src/geometry.c:1647
#, c-format
msgid "tag=%d: suppressing additional self-connection warnings\n"
msgstr "tag=%d: 追加の自己接続警告を抑制しています\n"

#: src/geometry.c:1692
#, c-format
msgid ""
"tag=%d/seg=%d: distance=%.3e to tag=%d/seg=%d closer than 2x connection "
"threshold %.3e; unintended connections possible\n"
msgstr ""
"tag=%d/seg=%d: 距離=%.3e（tag=%d/seg=%dまで）が接続閾値%.3eの2倍より近いで"
"す; 意図しない接続の可能性があります\n"

#: src/geometry.c:1697
#, c-format
msgid "tag=%d: suppressing additional overlap warnings\n"
msgstr "tag=%d: 追加の重複警告を抑制しています\n"

#: src/geometry.c:1757
#, c-format
msgid ""
"tag=%d/seg=%d: length=%.3e is too short (and close enough) to tag=%d/seg=%d "
"length=%.3e that connection detection may fail or short\n"
msgstr ""
"tag=%d/seg=%d: 長さ=%.3eが短すぎ（かつ十分近い）tag=%d/seg=%d 長さ=%.3eに対し"
"て接続検出が失敗またはショートする可能性があります\n"

#: src/geometry.c:1762
#, c-format
msgid ""
"tag=%d: suppressing additional connection detection may fail or short "
"warnings\n"
msgstr "tag=%d: 追加の接続検出失敗またはショート警告を抑制しています\n"

#: src/geometry.c:1794
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f < 0.001; similarity of "
"current components leads to numerical inaccuracies (min=0.001, fine=0.05, "
"recommended <= 0.1)\n"
msgstr ""
"tag=%d/seg=%d: 長さ/波長比 %.3f < 0.001; 電流成分の類似性が数値的不正確さを引"
"き起こします (min=0.001, fine=0.05, recommended <= 0.1)\n"

#: src/geometry.c:1799
#, c-format
msgid "tag=%d: suppressing additional short wavelength ratio errors\n"
msgstr "tag=%d: 追加の短波長比エラーを抑制しています\n"

#: src/geometry.c:1812
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.1; current sampling "
"resolution limited by segment spacing (min=0.001, fine=0.05, recommended <= "
"0.1)\n"
msgstr ""
"tag=%d/seg=%d: 長さ/波長比 %.3f > 0.1; 電流サンプリング解像度がセグメント間隔"
"により制限されています (min=0.001, fine=0.05, recommended <= 0.1)\n"

#: src/geometry.c:1817
#, c-format
msgid "tag=%d: suppressing additional long wavelength ratio warnings\n"
msgstr "tag=%d: 追加の長波長比警告を抑制しています\n"

#: src/geometry.c:1830
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.05; shorter segments "
"increase accuracy in regions of rapid current change (min=0.001, fine=0.05, "
"recommended <=0.1)\n"
msgstr ""
"tag=%d/seg=%d: 長さ/波長比 %.3f > 0.05; 電流変化が急速な領域では短いセグメン"
"トが精度を向上させます (min=0.001, fine=0.05, recommended <=0.1)\n"

#: src/geometry.c:1835
#, c-format
msgid "tag=%d: suppressing additional accuracy improvement suggestions\n"
msgstr "tag=%d: 追加の精度改善提案を抑制しています\n"

#: src/geometry.c:1865
#, c-format
msgid ""
"tag=%d/seg=%d: length/radius ratio of %.1f < 2.0; standard thin-wire kernel "
