msgstr ""
"tag=%d/seg=%d: 長さ/半径比 %.1f < 2.0; 標準細線カーネルの電界誤差が1%%を大幅"
"に超えています (min=2.0, 1%%accurate=8.0)\n"

#: src/geometry.c:1870
#, c-format
msgid "tag=%d: suppressing additional standard kernel ratio errors\n"
msgstr "tag=%d: 追加の標準カーネル比エラーを抑制しています\n"

#: src/geometry.c:1883
#, c-format
msgid ""
"tag=%d/seg=%d: length/radius ratio of %.1f < 8.0; standard thin-wire kernel "
"field error exceeds 1%% (min=2.0, 1%%accurate=8.0)\n"
msgstr ""
"tag=%d/seg=%d: 長さ/半径比 %.1f < 8.0; 標準細線カーネルの電界誤差が1%%を超え"
"ています (min=2.0, 1%%accurate=8.0)\n"

#: src/geometry.c:1888
#, c-format
msgid "tag=%d: suppressing additional standard kernel ratio warnings\n"
msgstr "tag=%d: 追加の標準カーネル比警告を抑制しています\n"

#: src/geometry.c:1903
#, c-format
msgid ""
"tag=%d/seg=%d: length/radius ratio of %.1f < 0.5; extended thin-wire kernel "
