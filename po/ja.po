#: src/geometry.c:1908
#, c-format
msgid "tag=%d: suppressing additional extended kernel ratio errors\n"
msgstr "tag=%d: 追加の拡張カーネル比エラーを抑制しています\n"

#: src/geometry.c:1921
#, c-format
msgid ""
"tag=%d/seg=%d: length/radius ratio of %.1f < 2.0; extended thin-wire kernel "
"field error exceeds 1%% (min=0.5, 1%%accurate=2.0)\n"
msgstr ""
"tag=%d/seg=%d: 長さ/半径比 %.1f < 2.0; 拡張細線カーネルの電界誤差が1%%を超え"
