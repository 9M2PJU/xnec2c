#: src/utils.c:45
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"Lietojums: xnec2c [opcijas] [<ievades-faila-nosaukums>]\n"
"  -i|--input         <ievades-faila-nosaukums>\n"
"  -c|--config        <konfigurācijas-faila-ceļš>     - failam jāeksistē\n"
"  -C|--new-config    <jauna-konfigurācijas-faila-ceļš> - izveido failu, ja "
"tas neeksistē\n"
"  -j|--jobs  <procesoru skaits SMP mašīnā> (-j0 atspējo sazarošanu)\n"
"     --openblas-threads <n>  iestatīt OpenBLAS pavedienu skaitu "
"(noklusējums: 1)\n"
"     --mkl-threads <n>       iestatīt Intel MKL pavedienu skaitu "
"(noklusējums: 1)\n"
"     --omp-threads <n>       iestatīt OpenMP pavedienu skaitu (noklusējums: "
"1)\n"
"  -b|--batch:        iespējot pakešu režīmu, iziet pēc frekvenču cikla "
"izpildes\n"
"  -P|--no-pthreads:  atspējot pthreads un izmantot GTK ciklu atkļūdošanai\n"
"  -h|--help:         parādīt lietošanas informāciju un iziet\n"
"  -V|--version:      parādīt xnec2c versijas numuru un iziet\n"
"  -v|--verbose:      palielināt detalizāciju, var norādīt vairākas reizes\n"
"  -d|--debug:        iespējot atkļūdošanas izvadi (-dd iekļauj izsaukumu "
"izsekošanu)\n"
"  -d|--quiet:        apslāpēt atkļūdošanas/detalizēto izvadi\n"
"\n"
"  --optimize:        Nekavējoties aktivizēt optimizētāju.\n"
"  --skip-verify:     izlaist ģeometrijas verifikācijas pārbaudes\n"
"\n"
"Šie argumenti raksta izvades failā pēc frekvenču cikla pabeigšanas.\n"
"Tos ir noderīgi kombinēt ar --batch; Ja vēlaties norādīt failu\n"
"nosaukumus rakstīšanai bez --batch režīma, tad iespējojiet Fails-"
">Optimizācijas\n"
"iestatījumi, pretējā gadījumā komandrindā norādītie faili netiks rakstīti.\n"
"\n"
"  --write-csv             <faila_nosaukums>  - rakstīt CSV failu ar "
"mērījumiem\n"
"  --write-s1p             <faila_nosaukums>  - rakstīt S1P failu ar S-"
"parametriem\n"
"  --write-s2p-max-gain    <faila_nosaukums>  - rakstīt S2P failu, port-2 ir "
"maksimālais pastiprinājums\n"
"  --write-s2p-viewer-gain <faila_nosaukums>  - rakstīt S2P failu, port-2 ir "
"skatītāja pastiprinājums\n"
"  --write-rdpat           <faila_nosaukums>  - rakstīt CSV ar starojuma "
"diagrammu\n"
"  --write-currents        <faila_nosaukums>  - rakstīt CSV ar strāvām un "
"lādiņiem\n"
"  --write-gnuplot-structure <faila_nosaukums> - rakstīt gnuplot struktūras "
"failu\n"
"  --write-patch-currents  <faila_nosaukums>  - rakstīt CSV ar plāksteru "
"virsmas strāvām\n"

