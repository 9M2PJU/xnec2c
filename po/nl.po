#: src/utils.c:45
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"Gebruik: xnec2c [opties] [<invoerbestandsnaam>]\n"
"  -i|--input         <invoerbestandsnaam>\n"
"  -c|--config        <configuratiebestandspad>     - bestand moet bestaan\n"
"  -C|--new-config    <nieuw-configuratiebestandspad> - maakt het bestand aan "
"indien ontbrekend\n"
"  -j|--jobs  <aantal processors in SMP-machine> (-j0 schakelt forking uit)\n"
"     --openblas-threads <n>  stel aantal OpenBLAS-threads in (standaard: 1)\n"
"     --mkl-threads <n>       stel aantal Intel MKL-threads in (standaard: "
"1)\n"
"     --omp-threads <n>       stel aantal OpenMP-threads in (standaard: 1)\n"
"  -b|--batch:        schakel batchmodus in, sluit af na voltooiing van de "
"frequentielus\n"
"  -P|--no-pthreads:  schakel pthreads uit en gebruik de GTK-lus voor "
"foutopsporing\n"
"  -h|--help:         toon gebruiksinformatie en sluit af\n"
"  -V|--version:      toon xnec2c-versienummer en sluit af\n"
"  -v|--verbose:      verhoog uitgebreidheid, kan meerdere keren worden "
"opgegeven\n"
"  -d|--debug:        schakel debug-uitvoer in (-dd bevat backtraces)\n"
"  -d|--quiet:        onderdruk debug/uitgebreide uitvoer\n"
"\n"
"  --optimize:        Activeer de optimizer onmiddellijk.\n"
"  --skip-verify:     sla geometrieverificatiecontroles over\n"
"\n"
"De volgende argumenten schrijven naar een uitvoerbestand na voltooiing van "
"de\n"
"frequentielus. Deze zijn nuttig om te combineren met --batch; als u "
"bestandsnamen\n"
"wilt opgeven om te schrijven zonder --batch-modus, schakel dan Bestand-"
">Optimizer-\n"
"instellingen in, anders worden de bestanden die u op de opdrachtregel "
"opgeeft\n"
"niet geschreven.\n"
"\n"
"  --write-csv             <bestandsnaam>  - schrijf CSV-bestand met "
"metingen\n"
"  --write-s1p             <bestandsnaam>  - schrijf S1P-bestand met S-"
"parameters\n"
"  --write-s2p-max-gain    <bestandsnaam>  - schrijf S2P-bestand, poort-2 is "
"max-gain\n"
"  --write-s2p-viewer-gain <bestandsnaam>  - schrijf S2P-bestand, poort-2 is "
"viewer-gain\n"
"  --write-rdpat           <bestandsnaam>  - schrijf CSV van het "
"stralingspatroon\n"
"  --write-currents        <bestandsnaam>  - schrijf CSV van stromen en "
"ladingen\n"
"  --write-gnuplot-structure <bestandsnaam> - schrijf gnuplot-"
"structuurbestand\n"
"  --write-patch-currents  <bestandsnaam>  - schrijf CSV van "
"oppervlaktestromen van patches\n"

