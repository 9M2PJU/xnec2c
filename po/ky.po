"жакшы=0.05, сунушталат <= 0.1)\n"

#: src/geometry.c:1633
#, c-format
msgid "tag=%d: suppressing additional long wavelength ratio warnings\n"
msgstr "тег=%d: кошумча узун толкун узундугу катышы эскертүүлөрү жашырылды\n"

#: src/geometry.c:1647
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.05; shorter segments "
