#: src/geometry.c:1707
#, c-format
msgid "tag=%d: suppressing additional standard kernel ratio warnings\n"
msgstr "тег=%d: кошумча стандарттык ядро катышы эскертүүлөрү жашырылды\n"

#: src/geometry.c:1723
#, c-format
msgid ""
"tag=%d/seg=%d: length/radius ratio of %.1f < 0.5; extended thin-wire kernel "
