#: src/geometry.c:1609
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f < 0.001; similarity of "
"current components leads to numerical inaccuracies (min=0.001, fine=0.05, "
"recommended <= 0.1)\n"
msgstr ""
"тег=%d/сег=%d: узундук/толкун узундугу катышы %.3f < 0.001; ток "
"компоненттеринин окшоштугу сандык так эместиктерге алып келет (мин=0.001, "
"жакшы=0.05, сунушталат <= 0.1)\n"

#: src/geometry.c:1614
#, c-format
msgid "tag=%d: suppressing additional short wavelength ratio errors\n"
msgstr "тег=%d: кошумча кыска толкун узундугу катышы каталары жашырылды\n"

#: src/geometry.c:1628
#, c-format
msgid ""
"tag=%d/seg=%d: length/wavelength ratio of %.3f > 0.1; current sampling "
