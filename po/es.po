#: src/utils.c:45
#, c-format
msgid ""
"Usage: xnec2c [options] [<input-file-name>]\n"
"  -i|--input         <input-file-name>\n"
"  -c|--config        <config-file-path>     - file must exist\n"
"  -C|--new-config    <new-config-file-path> - creates the file when missing\n"
"  -j|--jobs  <number of processors in SMP machine> (-j0 disables forking)\n"
"     --openblas-threads <n>  set OpenBLAS thread count (default: 1)\n"
"     --mkl-threads <n>       set Intel MKL thread count (default: 1)\n"
"     --omp-threads <n>       set OpenMP thread count (default: 1)\n"
"  -b|--batch:        enable batch mode, exit after the frequency loop runs\n"
"  -P|--no-pthreads:  disable pthreads and use the GTK loop for debugging\n"
"  -h|--help:         print usage information and exit\n"
"  -V|--version:      print xnec2c version number and exit\n"
"  -v|--verbose:      increase verbosity, can be specified multiple times\n"
"  -d|--debug:        enable debug output (-dd includes backtraces)\n"
"  -d|--quiet:        suppress debug/verbose output\n"
"\n"
"  --optimize:        Activate the optimizer immediately.\n"
"  --skip-verify:     skip geometry verification checks\n"
"\n"
"The following arguments write to an output file after the frequency loop\n"
"completes.  These are useful to combine with --batch; If you wish to "
"specify\n"
"filenames to write without --batch mode then enable the File->Optimizer\n"
"Settings or the files you specify on the command line will not be written.\n"
"\n"
"  --write-csv             <filename>  - write CSV file of measurements\n"
"  --write-s1p             <filename>  - write S1P file of S-parameters\n"
"  --write-s2p-max-gain    <filename>  - write S2P file, port-2 is max-gain\n"
"  --write-s2p-viewer-gain <filename>  - write S2P file, port-2 is viewer-"
"gain\n"
"  --write-rdpat           <filename>  - write CSV of the radiation pattern\n"
"  --write-currents        <filename>  - write CSV of currents and charges\n"
"  --write-gnuplot-structure <filename> - write gnuplot structure file\n"
"  --write-patch-currents  <filename>  - write CSV of patch surface currents\n"
msgstr ""
"Uso: xnec2c [opciones] [<nombre-archivo-entrada>]\n"
"  -i|--input         <nombre-archivo-entrada>\n"
"  -c|--config        <ruta-archivo-config>     - el archivo debe existir\n"
"  -C|--new-config    <ruta-nuevo-archivo-config> - crea el archivo si no "
"existe\n"
"  -j|--jobs  <número de procesadores en máquina SMP> (-j0 deshabilita "
"bifurcación)\n"
"     --openblas-threads <n>  establecer número de hilos OpenBLAS "
"(predeterminado: 1)\n"
"     --mkl-threads <n>       establecer número de hilos Intel MKL "
"(predeterminado: 1)\n"
"     --omp-threads <n>       establecer número de hilos OpenMP "
"(predeterminado: 1)\n"
"  -b|--batch:        habilitar modo por lotes, salir después de ejecutar el "
"bucle de frecuencia\n"
"  -P|--no-pthreads:  deshabilitar pthreads y usar el bucle GTK para "
"depuración\n"
"  -h|--help:         mostrar información de uso y salir\n"
"  -V|--version:      mostrar número de versión de xnec2c y salir\n"
"  -v|--verbose:      aumentar verbosidad, se puede especificar múltiples "
"veces\n"
"  -d|--debug:        habilitar salida de depuración (-dd incluye trazas de "
"pila)\n"
"  -d|--quiet:        suprimir salida de depuración/verbosidad\n"
"\n"
"  --optimize:        Activar el optimizador inmediatamente.\n"
"  --skip-verify:     omitir verificaciones de geometría\n"
"\n"
"Los siguientes argumentos escriben a un archivo de salida después de "
"completar\n"
"el bucle de frecuencia. Son útiles para combinar con --batch; Si desea "
"especificar\n"
"nombres de archivo para escribir sin modo --batch, habilite Archivo-"
">Configuración\n"
"del Optimizador o los archivos especificados en la línea de comandos no se "
"escribirán.\n"
"\n"
"  --write-csv             <nombre-archivo>  - escribir archivo CSV de "
"mediciones\n"
"  --write-s1p             <nombre-archivo>  - escribir archivo S1P de "
"parámetros S\n"
"  --write-s2p-max-gain    <nombre-archivo>  - escribir archivo S2P, puerto-2 "
"es ganancia máxima\n"
"  --write-s2p-viewer-gain <nombre-archivo>  - escribir archivo S2P, puerto-2 "
"es ganancia del visor\n"
"  --write-rdpat           <nombre-archivo>  - escribir CSV del patrón de "
"radiación\n"
"  --write-currents        <nombre-archivo>  - escribir CSV de corrientes y "
"cargas\n"
"  --write-gnuplot-structure <nombre-archivo> - escribir archivo de "
"estructura gnuplot\n"
"  --write-patch-currents  <nombre-archivo>  - escribir CSV de corrientes de "
"superficie de parche\n"

